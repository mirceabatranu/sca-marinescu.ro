---
import type { SiteContent } from '../data/site';
import { companyProfile } from '../data/site';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const menuLabel = content.lang === 'ro' ? 'Meniu' : 'Menu';
const closeLabel = content.lang === 'ro' ? 'Închide' : 'Close';
---

<!-- BACKDROP -->
<div class="nav-overlay-backdrop" id="navBackdrop"></div>

<!-- MENU OVERLAY PANEL -->
<div class="nav-overlay-panel" id="navOverlay" role="dialog" aria-modal="true" aria-label={menuLabel}>
  <div class="nav-overlay-top">
    <button class="nav-overlay-close" id="navClose" aria-label={closeLabel}>
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
        <line x1="2" y1="2" x2="20" y2="20" stroke="currentColor" stroke-width="1.5"/>
        <line x1="20" y1="2" x2="2" y2="20" stroke="currentColor" stroke-width="1.5"/>
      </svg>
      <span class="nav-overlay-close-label">{closeLabel}</span>
    </button>
  </div>

  <nav class="nav-overlay-links" aria-label={content.navigationLabel}>
    {content.navigation.map((item) => (
      <a href={item.href} class="nav-overlay-link">{item.label}</a>
    ))}
  </nav>

  <div class="nav-overlay-footer">
    <a href={content.switch.href} hreflang={content.switch.hrefLang} class="nav-overlay-lang">
      {content.switch.label} — {content.switch.caption}
    </a>
  </div>
</div>

<header class="site-header" id="siteHeader">
  <div class="shell nav-shell">
    <a class="brand" href={content.homePath} aria-label={content.brand.ariaLabel}>
      <img src="/company-logo.svg" alt={companyProfile.name} class="brand-logo" />
    </a>

    <div class="nav-controls">
      <a class="language-link" href={content.switch.href} hreflang={content.switch.hrefLang}>
        <span>{content.switch.label}</span>
        <small>{content.switch.caption}</small>
      </a>

      <button class="nav-menu-toggle" id="navMenuToggle" aria-label={menuLabel} aria-expanded="false">
        <span class="nav-hamburger">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span class="nav-menu-label">{menuLabel}</span>
      </button>
    </div>
  </div>
</header>

<main>
  <section class="hero-section" id="top">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{content.hero.eyebrow}</p>
        <h1>{content.hero.title}</h1>
        <p class="hero-summary">{content.hero.summary}</p>

        <div class="hero-actions">
          <a class="button button-primary" href={content.hero.primaryCta.href}>{content.hero.primaryCta.label}</a>
          <a class="button button-secondary" href={content.hero.secondaryCta.href}>{content.hero.secondaryCta.label}</a>
        </div>
      </div>

      <aside class="hero-panel" aria-label={content.hero.panelLabel}>
        <p class="panel-kicker">{content.hero.panelKicker}</p>
        <ul class="panel-list">
          {content.hero.panelItems.map((item) => (
            <li>
              <strong>{item.title}</strong>
              <span>{item.description}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </section>

  <section class="credibility-strip" aria-label={content.signalsLabel}>
    <div class="shell signal-grid">
      {content.signals.map((item) => (
        <article class="signal-card">
          <p>{item.title}</p>
          <span>{item.description}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block" id="services">
    <div class="shell">
      <div class="section-heading">
        <p class="eyebrow">{content.practiceIntro.eyebrow}</p>
        <h2>{content.practiceIntro.title}</h2>
        <p>{content.practiceIntro.summary}</p>
      </div>

      <div class="practice-grid">
        {content.practiceAreas.map((item) => (
          <article class="practice-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-block contrast-block" id="approach">
    <div class="shell split-grid">
      <div>
        <p class="eyebrow">{content.approach.eyebrow}</p>
        <h2>{content.approach.title}</h2>
        <p class="section-lead">{content.approach.summary}</p>
      </div>

      <div class="approach-steps">
        {content.approach.steps.map((item) => (
          <article>
            <strong>{item.title}</strong>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-block" id="matters">
    <div class="shell">
      <div class="section-heading narrow-heading">
        <p class="eyebrow">{content.mandates.eyebrow}</p>
        <h2>{content.mandates.title}</h2>
        <p>{content.mandates.summary}</p>
      </div>

      <div class="mandate-grid">
        {content.mandates.items.map((item) => (
          <article class="mandate-card">
            <p class="mandate-sector">{item.sector}</p>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-block faq-block" id="insights">
    <div class="shell split-grid">
      <div>
        <p class="eyebrow">{content.faqIntro.eyebrow}</p>
        <h2>{content.faqIntro.title}</h2>
        <p class="section-lead">{content.faqIntro.summary}</p>
      </div>

      <div class="faq-list">
        {content.faqs.map((item) => (
          <article>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-block contact-block" id="contact">
    <div class="shell contact-grid">
      <div>
        <p class="eyebrow">{content.contact.eyebrow}</p>
        <h2>{content.contact.title}</h2>
        <p class="section-lead">{content.contact.summary}</p>
      </div>

      <div class="contact-card">
        <div>
          <span>{content.contact.emailLabel}</span>
          <a href={`mailto:${companyProfile.email}`}>{companyProfile.email}</a>
        </div>
        <div>
          <span>{content.contact.locationLabel}</span>
          <p>{companyProfile.city}, {companyProfile.country}</p>
        </div>
        <div>
          <span>{content.contact.languagesLabel}</span>
          <p>{content.contact.languages}</p>
        </div>
        <a class="button button-primary" href={content.contact.cta.href}>{content.contact.cta.label}</a>
      </div>
    </div>
  </section>
</main>

<footer class="site-footer">
  <div class="shell footer-shell">
    <p>{content.footer.statement}</p>
    <div class="footer-links">
      {content.footer.links.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </div>
  </div>
</footer>

<script>
  const overlay = document.getElementById('navOverlay');
  const toggle = document.getElementById('navMenuToggle');
  const closeBtn = document.getElementById('navClose');
  const backdrop = document.getElementById('navBackdrop');
  const header = document.getElementById('siteHeader');

  function openMenu() {
    overlay?.classList.add('open');
    backdrop?.classList.add('visible');
    header?.classList.add('menu-open');
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    overlay?.classList.remove('open');
    backdrop?.classList.remove('visible');
    header?.classList.remove('menu-open');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    if (overlay?.classList.contains('open')) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('open')) closeMenu();
  });

  document.querySelectorAll('.nav-overlay-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
