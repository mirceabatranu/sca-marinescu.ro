<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Commercial Litigation in Romania | SCA Marinescu</title>
  <meta name="description" content="SCA Marinescu — law firm specialising in commercial litigation, arbitration and corporate disputes in Romania." />
  <link rel="canonical" href="https://sca-marinescu.ro/en/" />
  <link rel="alternate" href="https://sca-marinescu.ro/" hreflang="ro-RO" />
  <link rel="alternate" href="https://sca-marinescu.ro/en/" hreflang="en" />
  <link rel="alternate" href="https://sca-marinescu.ro/" hreflang="x-default" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #C9A55A;
      --dark: #0E0D0C;
      --dark-nav: #131210;
      --off-white: #F0EBE0;
      --gray: #6B6860;
      --gray-light: #9A9590;
      --nav-h: 90px; /* 58px logo + 2×16px padding */
    }

    html, body { height: 100%; overflow-x: hidden; }

    html { scroll-padding-top: var(--nav-h); }

    body {
      font-family: 'Georgia', serif;
      background: var(--dark);
      color: var(--off-white);
    }

    /* ── TOPBAR ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 300;
      display: flex;
      align-items: center;
      padding: 1rem 2.5rem;
      min-height: var(--nav-h);
      background: var(--dark-nav);
      border-bottom: 1px solid rgba(201,165,90,0.12);
    }

    .logo {
      text-decoration: none;
      flex-shrink: 0;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .logo-image {
      display: block;
      height: 58px;
      width: auto;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-left: auto;
    }

    .lang-switch {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.56rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--gold);
      border: 1px solid rgba(201,165,90,0.35);
      padding: 0.45rem 0.7rem;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
      white-space: nowrap;
    }

    .lang-switch:hover {
      color: var(--off-white);
      border-color: var(--gold);
      background: rgba(201,165,90,0.12);
    }

    .menu-btn-icon {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 4px;
    }

    .menu-btn-icon span {
      display: block;
      height: 1.5px;
      background: var(--gold);
    }
    .menu-btn-icon span:nth-child(1) { width: 22px; }
    .menu-btn-icon span:nth-child(2) { width: 16px; }
    .menu-btn-icon span:nth-child(3) { width: 22px; }

    .menu-btn-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.5rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-top: 0.3rem;
    }

    .menu-btn-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      cursor: pointer;
      background: none;
      border: none;
    }

    @media (min-width: 901px) {
      nav.menu-open .logo {
        transform: translateX(-2rem);
      }
    }

    /* ── BACKDROP ── */
    .overlay-backdrop {
      position: fixed;
      inset: 0;
      z-index: 199;
      background: rgba(0, 0, 0, 0.55);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.4s ease;
    }

    .overlay-backdrop.visible {
      opacity: 1;
      pointer-events: all;
    }

    /* ── MENU OVERLAY ── */
    .overlay {
      position: fixed;
      top: 0; right: 0;
      width: 40%;
      height: 100vh;
      z-index: 200;
      background: #0E0D0C;
      display: flex;
      flex-direction: column;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      overflow-y: auto;
      overflow-x: hidden;
      border-left: 1px solid rgba(201,165,90,0.14);
    }

    .overlay.open { transform: translateX(0); }

    .overlay-top {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 1.6rem 2rem;
      flex-shrink: 0;
    }

    .close-btn {
      background: none; border: none; cursor: pointer;
      display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
      color: var(--off-white);
      transition: color 0.2s;
    }

    .close-btn:hover { color: var(--gold); }
    .close-btn svg { stroke: currentColor; stroke-width: 1.5; }

    .close-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.5rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: inherit;
    }

    .overlay-nav {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding: 1rem 3rem;
      gap: 0.4rem;
    }

    .overlay-nav a {
      font-size: clamp(1.6rem, 2.8vw, 2.4rem);
      font-weight: 400;
      text-decoration: none;
      color: var(--off-white);
      line-height: 1.35;
      transition: color 0.2s;
      font-family: 'Georgia', serif;
    }

    .overlay-nav a:hover { color: var(--gold); }

    .overlay-footer {
      display: flex;
      align-items: flex-end;
      justify-content: flex-end;
      padding: 1.5rem 2rem;
      flex-shrink: 0;
      border-top: 1px solid rgba(201,165,90,0.1);
    }

    .overlay-legal {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.58rem;
      color: rgba(240, 235, 224, 0.42);
      letter-spacing: 0.05em;
      text-align: right;
      line-height: 1.6;
    }

    .overlay-legal a { color: rgba(240, 235, 224, 0.42); text-decoration: none; }
    .overlay-legal a:hover { color: var(--gold); }

    /* ── HERO — full-width, centered ── */
    .hero {
      height: calc(100vh - var(--nav-h));
      height: calc(100svh - var(--nav-h)); /* iOS Safari: stable viewport height */
      margin-top: var(--nav-h);
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
    }

    .hero-bg svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: rgba(6, 8, 8, 0.52);
    }

    .hero-center {
      position: relative;
      z-index: 2;
      text-align: center;
      padding: 2rem clamp(1.5rem, 6vw, 5rem);
      max-width: min(900px, 92vw);
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    .hero-eyebrow {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.62rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
      margin: 0 0 1.1rem;
    }

    .hero-main-title {
      font-size: clamp(1.7rem, 3.8vw, 3rem);
      font-weight: 400;
      line-height: 1.18;
      color: var(--off-white);
      margin: 0 0 1.3rem;
      max-width: 780px;
    }

    .hero-summary {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.97rem;
      line-height: 1.78;
      color: rgba(240,235,224,0.70);
      max-width: 600px;
      margin: 0;
    }

    .hero-cta {
      margin-top: 1.6rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--off-white);
      border: 1px solid rgba(201,165,90,0.5);
      background: rgba(201,165,90,0.18);
      padding: 0.72rem 1rem;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }

    .hero-cta:hover {
      color: var(--gold);
      border-color: var(--gold);
      background: rgba(201,165,90,0.08);
    }

    .hero-carousel-bar {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0 2.5rem 2.5rem;
      flex-shrink: 0;
    }

    .carousel-tabs {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .carousel-arrow {
      background: none; border: none; cursor: pointer;
      color: var(--gold); font-size: 1.2rem;
      transition: color 0.2s;
      padding: 0.2rem 0.4rem;
    }
    .carousel-arrow:hover { color: var(--off-white); }

    .carousel-tab {
      border: none;
      background: transparent;
      color: var(--gray-light);
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 0.2rem 0.25rem 0.62rem;
      cursor: pointer;
      position: relative;
      transition: color 0.2s;
    }

    .carousel-tab::after {
      content: '';
      position: absolute;
      left: 0; right: 0; bottom: 0;
      height: 2px;
      background: var(--gray);
      transition: background 0.2s, height 0.2s;
    }

    .carousel-tab.active { color: var(--off-white); }
    .carousel-tab.active::after { height: 3px; background: var(--off-white); }
    .carousel-tab:hover { color: var(--gold); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .overlay { width: 100%; border-left: none; }
      .overlay-nav { align-items: flex-start; padding: 1rem 2rem; }
      .overlay-footer { justify-content: flex-start; }
      .overlay-legal { text-align: left; }
    }

    @media (max-width: 1024px) {
      :root { --nav-h: 78px; } /* 49px logo + 2×0.9rem padding ≈ 78px */

      nav { padding: 0.9rem 1.2rem; min-height: var(--nav-h); }
      .logo-image { height: 49px; }
    }

    @media (max-width: 720px) {
      .logo-image { height: 43px; }
      .lang-switch { font-size: 0.5rem; letter-spacing: 0.14em; padding: 0.4rem 0.5rem; }
      .menu-btn-label { display: none; }
      .hero-carousel-bar { padding: 0 1.2rem 1.8rem; gap: 0.5rem; }
      .carousel-tab { font-size: 0.53rem; }
      .hero-center { padding: 1.5rem 1.2rem; }
    }

    @media (max-height: 700px) and (orientation: landscape) {
      :root { --nav-h: 60px; } /* 40px logo + 2×0.6rem padding = ~59px, min-height governs */

      nav { min-height: var(--nav-h); padding-top: 0.6rem; padding-bottom: 0.6rem; }
      .logo-image { height: 40px; }
      .hero-main-title { font-size: clamp(1.3rem, 3.5vw, 2.2rem); }
      .hero-summary { display: none; }
    }
  </style>
</head>
<body>

  <!-- BACKDROP -->
  <div class="overlay-backdrop" id="overlayBackdrop"></div>

  <!-- MENU OVERLAY PANEL -->
  <div class="overlay" id="overlay" role="dialog" aria-modal="true" aria-label="Main menu">
    <div class="overlay-top">
      <button class="close-btn" id="closeBtn" aria-label="Close menu">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <line x1="2" y1="2" x2="20" y2="20"/>
          <line x1="20" y1="2" x2="2" y2="20"/>
        </svg>
        <span class="close-label">Close</span>
      </button>
    </div>

    <nav class="overlay-nav">
      <a href="/en/" onclick="closeOverlay()">Home</a>
      <a href="#about" onclick="closeOverlay()">About Us</a>
      <a href="#services" onclick="closeOverlay()">Practice Areas</a>
      <a href="#insights" onclick="closeOverlay()">Legal Blog</a>
      <a href="#contact" onclick="closeOverlay()">Contact</a>
    </nav>

    <footer class="overlay-footer">
      <div class="overlay-legal">
        &copy; 2026 Societatea Civilă de Avocatură Marinescu &amp; Asociații
      </div>
    </footer>
  </div>

  <!-- TOPBAR -->
  <nav id="mainNav">
    <a href="/en/" class="logo" aria-label="SCA Marinescu, home page">
      <img src="/company-logo-gold.svg" alt="Marinescu &amp; Asociații" class="logo-image" />
    </a>

    <div class="nav-right">
      <a href="/" class="lang-switch" hreflang="ro" aria-label="Versiune română">RO</a>

      <button class="menu-btn-wrap" id="menuBtn" aria-label="Open menu" aria-expanded="false">
        <div class="menu-btn-icon">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <span class="menu-btn-label">Menu</span>
      </button>
    </div>
  </nav>

  <!-- HERO — centered layout with full-width wave background -->
  <div class="hero">

    <!-- Wave background -->
    <div class="hero-bg">
      <svg viewBox="0 0 900 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="waveBgEn" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#1A3040"/>
            <stop offset="50%" stop-color="#0E2030"/>
            <stop offset="100%" stop-color="#060E14"/>
          </linearGradient>
        </defs>
        <rect width="900" height="900" fill="url(#waveBgEn)"/>
        <g fill="none" stroke-width="0.8">
          <path d="M450,900 C420,750 380,600 450,450 S560,250 450,100 S280,-50 150,50" stroke="rgba(160,210,240,0.15)"/>
          <path d="M450,900 C415,745 370,590 445,440 S560,235 448,88 S270,-60 143,40" stroke="rgba(160,210,240,0.13)"/>
          <path d="M450,900 C408,738 362,578 440,428 S562,220 446,76 S263,-70 136,30" stroke="rgba(160,210,240,0.11)"/>
          <path d="M450,900 C400,730 354,566 434,416 S564,204 444,64 S256,-80 128,20" stroke="rgba(160,210,240,0.09)"/>
          <path d="M450,900 C392,722 346,554 428,404 S566,188 442,52 S249,-90 121,10" stroke="rgba(160,210,240,0.07)"/>
          <path d="M450,900 C384,714 338,542 422,392 S568,172 440,40 S242,-100 114,0" stroke="rgba(160,210,240,0.06)"/>
          <path d="M750,900 C720,750 680,600 750,450 S830,250 750,100 S640,-30 560,70" stroke="rgba(160,210,240,0.12)"/>
          <path d="M750,900 C715,745 670,590 745,440 S830,235 748,88 S630,-40 552,60" stroke="rgba(160,210,240,0.09)"/>
          <path d="M750,900 C708,738 662,578 740,428 S832,220 746,76 S622,-50 544,50" stroke="rgba(160,210,240,0.07)"/>
          <path d="M450,900 C435,755 402,608 458,460 S528,262 456,112" stroke="rgba(190,230,250,0.30)"/>
          <path d="M450,900 C438,758 408,614 463,466 S526,268 459,118" stroke="rgba(190,230,250,0.22)"/>
          <path d="M450,900 C441,761 414,620 468,472 S524,274 462,124" stroke="rgba(190,230,250,0.16)"/>
        </g>
        <path d="M450,900 C430,750 395,598 452,448 S531,248 452,98" fill="none" stroke="rgba(201,165,90,0.28)" stroke-width="1.8"/>
        <path d="M750,900 C730,750 700,595 752,445 S828,248 750,98" fill="none" stroke="rgba(201,165,90,0.18)" stroke-width="1.4"/>
      </svg>
    </div>

    <!-- Dark overlay -->
    <div class="hero-overlay"></div>

    <!-- Centered content — changes with carousel -->
    <div class="hero-center">
      <p class="hero-eyebrow" id="heroEyebrow">Protecting your business and personal interests with strategic, results-driven legal solutions.</p>
      <h1 class="hero-main-title" id="heroTitle">SCA Marinescu | Expert Legal Counsel &amp; Dedicated Advocacy in Romania</h1>
      <p class="hero-summary" id="heroSummary">At SCA Marinescu, we do more than just navigate the law; we provide proactive strategies to secure your future. As a premier Societate Civila de Avocati, our team specializes in corporate law, civil litigation, and comprehensive legal consulting for both businesses and individuals. Whether you are closing a complex merger, facing a high-stakes dispute, or needing day-to-day legal compliance, we deliver clear, actionable, and personalized solutions.</p>
      <a class="hero-cta" href="mailto:contact@sca-marinescu.ro?subject=Schedule%20a%20Consultation">Schedule a Consultation</a>
    </div>

    <!-- Carousel tabs at bottom -->
    <div class="hero-carousel-bar">
      <button class="carousel-arrow" id="prevSlide" aria-label="Previous">&#8249;</button>
      <div class="carousel-tabs" role="tablist" aria-label="Categories">
        <button class="carousel-tab active" type="button" role="tab" aria-selected="true" data-slide="0">Services</button>
        <button class="carousel-tab" type="button" role="tab" aria-selected="false" data-slide="1">Clients</button>
        <button class="carousel-tab" type="button" role="tab" aria-selected="false" data-slide="2">Commercial Litigation</button>
      </div>
      <button class="carousel-arrow" id="nextSlide" aria-label="Next">&#8250;</button>
    </div>

  </div>

  <script>
    // ── Menu overlay ──
    const overlay = document.getElementById('overlay');
    const menuBtn = document.getElementById('menuBtn');
    const closeBtn = document.getElementById('closeBtn');
    const backdrop = document.getElementById('overlayBackdrop');
    const navEl = document.getElementById('mainNav');

    function openOverlay() {
      overlay.classList.add('open');
      backdrop.classList.add('visible');
      navEl.classList.add('menu-open');
      menuBtn.setAttribute('aria-expanded', 'true');
    }

    function closeOverlay() {
      overlay.classList.remove('open');
      backdrop.classList.remove('visible');
      navEl.classList.remove('menu-open');
      menuBtn.setAttribute('aria-expanded', 'false');
    }

    menuBtn.addEventListener('click', () => {
      overlay.classList.contains('open') ? closeOverlay() : openOverlay();
    });

    closeBtn.addEventListener('click', closeOverlay);
    backdrop.addEventListener('click', closeOverlay);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('open')) closeOverlay();
    });

    // ── Carousel ──
    const slides = [
      {
        eyebrow: 'Protecting your business and personal interests with strategic, results-driven legal solutions.',
        title: 'SCA Marinescu | Expert Legal Counsel & Dedicated Advocacy in Romania',
        summary: 'At SCA Marinescu, we do more than just navigate the law; we provide proactive strategies to secure your future. As a premier Societate Civila de Avocati, our team specializes in corporate law, civil litigation, and comprehensive legal consulting for both businesses and individuals. Whether you are closing a complex merger, facing a high-stakes dispute, or needing day-to-day legal compliance, we deliver clear, actionable, and personalized solutions.',
      },
      {
        eyebrow: 'Clients',
        title: 'Counsel for Companies and International Groups',
        summary: 'We work with commercial entities, shareholder groups and foreign partners who need legal clarity in high-stakes Romanian disputes.',
      },
      {
        eyebrow: 'Commercial Litigation',
        title: 'Contract Disputes, Arbitration and Debt Recovery',
        summary: 'Experience in complex matters: contractual non-performance, corporate deadlock, institutional arbitration and debt recovery with asset dissipation risk.',
      },
    ];

    const tabButtons = document.querySelectorAll('.carousel-tab');
    const prevSlide = document.getElementById('prevSlide');
    const nextSlide = document.getElementById('nextSlide');
    let activeIndex = 0;

    function renderSlide(index) {
      activeIndex = index;
      tabButtons.forEach((btn, i) => {
        const active = i === index;
        btn.classList.toggle('active', active);
        btn.setAttribute('aria-selected', String(active));
      });
      const s = slides[index];
      document.getElementById('heroEyebrow').textContent = s.eyebrow;
      document.getElementById('heroTitle').textContent = s.title;
      document.getElementById('heroSummary').textContent = s.summary;
    }

    tabButtons.forEach((btn, i) => btn.addEventListener('click', () => renderSlide(i)));
    prevSlide.addEventListener('click', () => renderSlide((activeIndex - 1 + slides.length) % slides.length));
    nextSlide.addEventListener('click', () => renderSlide((activeIndex + 1) % slides.length));

    renderSlide(0);
  </script>
</body>
</html>
