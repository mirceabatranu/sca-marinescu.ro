      </g>
    </svg>

    <div class="overlay-top">
      <button class="close-btn" id="closeBtn" aria-label="Închide meniu">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <line x1="2" y1="2" x2="20" y2="20"/>
          <line x1="20" y1="2" x2="2" y2="20"/>
        </svg>
        <span class="close-label">Meniu</span>
      </button>

      <a href="/demo/1" class="overlay-logo">
        <img src="/company-logo-gold.svg" alt="Marinescu &amp; Asociații" class="logo-image" />
      </a>

      <div style="width:60px"></div><!-- balance spacer -->
    </div>

    <nav class="overlay-nav">
      <a href="#avocati" class="accent" onclick="closeOverlay()">Avocați</a>
      <a href="#servicii" class="accent" onclick="closeOverlay()">Servicii</a>
      <a href="#angajament" class="accent" onclick="closeOverlay()">Angajament Social</a>
      <a href="#cariere" class="accent" onclick="closeOverlay()">Cariere</a>
      <a href="#noutati" onclick="closeOverlay()">Noutăți &amp; Articole</a>
      <a href="#locatii" onclick="closeOverlay()">Locații</a>
      <a href="#despre" onclick="closeOverlay()">Despre Noi</a>
    </nav>

    <footer class="overlay-footer">
      <div class="socials">
        <a href="#" class="social-icon" aria-label="LinkedIn">in</a>
        <a href="#" class="social-icon" aria-label="Facebook">f</a>
      </div>
      <div class="overlay-legal">
        <a href="#">Absolvenți</a> / <a href="#">Politică &amp; Disclaimer</a> / <a href="#">Publicitate Juridică</a>
        <br />&copy; 2026 Societatea Civilă de Avocatură Marinescu &amp; Asociații
      </div>
    </footer>
  </div>

  <!-- TOPBAR -->
  <nav>
    <div class="nav-left">
      <button class="search-btn" aria-label="Căutare">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="7.5" cy="7.5" r="5.5"/>
          <line x1="11.5" y1="11.5" x2="16" y2="16"/>
        </svg>
      </button>
    </div>

    <a href="/demo/1" class="logo">
      <img src="/company-logo-gold.svg" alt="Marinescu &amp; Asociații" class="logo-image" />
    </a>

    <div class="nav-right">
      <a href="/demo/2" class="template-switch" aria-label="Comută la Template 2">Template 2</a>

      <button class="menu-btn-wrap" id="menuBtn" aria-label="Deschide meniu" aria-expanded="false">
        <div class="menu-btn">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <span class="menu-label">Meniu</span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <div class="hero">
    <!-- Left abstract wave panel -->
    <div class="hero-image">
      <svg viewBox="0 0 640 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="waveBg" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#1A3040"/>
