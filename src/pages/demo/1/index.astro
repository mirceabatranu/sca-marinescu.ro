          <linearGradient id="waveShine" x1="20%" y1="0%" x2="80%" y2="100%">
            <stop offset="0%" stop-color="#A8D8F0" stop-opacity="0.6"/>
            <stop offset="40%" stop-color="#7AB8D8" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="#3A6080" stop-opacity="0"/>
          </linearGradient>
        </defs>
        <rect width="640" height="900" fill="url(#waveBg)"/>
        <!-- Concentric ribbon waves imitating K&E hero -->
        <g fill="none" stroke-width="0.8">
          <path d="M320,900 C300,750 260,600 320,450 S400,250 320,100 S200,-50 100,50" stroke="rgba(160,210,240,0.18)"/>
          <path d="M320,900 C295,745 250,590 315,440 S400,235 318,88 S193,-60 93,40" stroke="rgba(160,210,240,0.16)"/>
          <path d="M320,900 C288,738 242,578 310,428 S402,220 316,76 S186,-70 86,30" stroke="rgba(160,210,240,0.14)"/>
          <path d="M320,900 C280,730 234,566 304,416 S404,204 314,64 S178,-80 78,20" stroke="rgba(160,210,240,0.12)"/>
          <path d="M320,900 C272,722 226,554 298,404 S406,188 312,52 S171,-90 71,10" stroke="rgba(160,210,240,0.10)"/>
          <path d="M320,900 C264,714 218,542 292,392 S408,172 310,40 S164,-100 64,0" stroke="rgba(160,210,240,0.09)"/>
