<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Demo 1 — Marinescu & Asociații</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #C9A55A;
      --gold-dim: rgba(201,165,90,0.4);
      --dark: #0E0D0C;
      --dark-nav: #131210;
      --off-white: #F0EBE0;
      --gray: #6B6860;
      --gray-light: #9A9590;
    }

    html, body { height: 100%; }

    body {
      font-family: 'Georgia', serif;
      background: var(--dark);
      color: var(--off-white);
      overflow: hidden;
    }

    /* ── TOPBAR ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      padding: 1.4rem 2.5rem;
      min-height: 86px;
      background: var(--dark-nav);
      border-bottom: 1px solid rgba(201,165,90,0.12);
    }

    .nav-left { display: flex; align-items: center; gap: 0.5rem; }

    .search-btn {
      background: none; border: none; cursor: pointer;
      color: var(--off-white); opacity: 0.7;
      padding: 0.3rem;
      font-size: 1rem;
      transition: opacity 0.2s;
    }
    .search-btn:hover { opacity: 1; }

    .logo {
      position: relative;
      justify-self: center;
      text-align: center;
      text-decoration: none;
      background: var(--dark-nav);
      border: 1px solid rgba(201,165,90,0.28);
      padding: 0.38rem 0.62rem;
      max-width: min(78vw, 420px);
    }

    .logo-image {
      display: block;
      width: 100%;
      height: auto;
    }

    .logo-monogram {
      display: block;
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--gold);
      letter-spacing: 0.08em;
      line-height: 1;
    }

    .logo-name {
      display: block;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.5rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: rgba(240,235,224,0.6);
      margin-top: 0.2rem;
    }

    .menu-btn {
      background: none; border: none; cursor: pointer;
      display: flex; flex-direction: column;
      align-items: flex-end;
      gap: 4px;
      padding: 0.3rem;
    }

    .menu-btn span {
      display: block;
      height: 1.5px;
      background: var(--gold);
      transition: width 0.2s;
    }
    .menu-btn span:nth-child(1) { width: 22px; }
    .menu-btn span:nth-child(2) { width: 16px; }
    .menu-btn span:nth-child(3) { width: 22px; }

    .menu-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.5rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-top: 0.3rem;
    }

    .menu-btn-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      cursor: pointer;
      background: none;
      border: none;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .template-switch {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.56rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--gold);
      border: 1px solid rgba(201,165,90,0.35);
      padding: 0.45rem 0.7rem;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
      white-space: nowrap;
    }

    .template-switch:hover {
      color: var(--off-white);
      border-color: var(--gold);
      background: rgba(201,165,90,0.12);
    }

    /* ── HERO ── */
    .hero {
      height: calc(100vh - 86px);
      margin-top: 86px;
      display: grid;
      grid-template-columns: 45% 55%;
    }

    /* Left: abstract wave image */
    .hero-image {
      position: relative;
      overflow: hidden;
    }

    /* SVG wave lines to simulate the K&E abstract */
    .hero-image svg {
      width: 100%; height: 100%;
      position: absolute; inset: 0;
    }

    /* Right: content panel */
    .hero-content {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 4rem 5rem 3.5rem;
      background: var(--dark);
    }

    .hero-eyebrow {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .hero-title {
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 400;
      line-height: 1.18;
      color: var(--off-white);
      margin-bottom: 1rem;
      max-width: 420px;
    }

    .hero-summary {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.85rem;
      line-height: 1.75;
      color: rgba(240,235,224,0.72);
      max-width: 520px;
    }

    /* Bottom carousel bar */
    .carousel-bar {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.4rem 2.5rem;
      z-index: 50;
    }

    .carousel-tabs {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .carousel-arrow {
      background: none; border: none; cursor: pointer;
      color: var(--gold); font-size: 1.1rem;
    }

    .carousel-tab {
      border: 1px solid rgba(201,165,90,0.25);
      background: transparent;
      color: var(--gray-light);
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 0.45rem 0.65rem;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
    }

    .carousel-tab.active {
      color: var(--off-white);
      background: rgba(201,165,90,0.12);
      border-color: var(--gold);
    }

    .more-news {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
    }
    .more-news:hover { color: var(--off-white); }

    /* ── MENU OVERLAY ── */
    .overlay {
      position: fixed;
      inset: 0;
      z-index: 200;
      background: #EDEAE5;
      display: flex;
      flex-direction: column;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.35s ease;
      overflow: hidden;
    }

    .overlay.open {
      opacity: 1;
      pointer-events: all;
    }

    /* Topographic line background */
    .overlay-bg {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .overlay-top {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.4rem 2.5rem;
    }

    .overlay-logo {
      text-align: center;
      text-decoration: none;
    }

    .overlay-logo .logo-monogram { color: var(--gold); font-size: 1.4rem; }
    .overlay-logo .logo-name { color: #888; margin-top: 0.2rem; }

    .close-btn {
      background: none; border: none; cursor: pointer;
      display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
    }

    .close-btn svg {
      stroke: #8B1A1A; stroke-width: 1.5;
    }

    .close-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.5rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #8B1A1A;
    }

    .overlay-nav {
      position: relative;
      z-index: 1;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-end;
      padding: 2rem 3.5rem;
      gap: 0.4rem;
    }

    .overlay-nav a {
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 400;
      text-decoration: none;
      color: #1A1A1A;
      line-height: 1.3;
      transition: color 0.2s;
      font-family: 'Georgia', serif;
    }

    .overlay-nav a.accent { color: #1A2EC0; }
    .overlay-nav a.accent:hover { color: #0D1F8A; }
    .overlay-nav a:not(.accent):hover { color: var(--gold); }

    .overlay-footer {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      padding: 1.5rem 2.5rem;
    }

    .socials { display: flex; gap: 0.6rem; }

    .social-icon {
      width: 36px; height: 36px;
      border: 1px solid #ccc;
      display: flex; align-items: center; justify-content: center;
      text-decoration: none; color: #555;
      font-family: sans-serif; font-size: 0.7rem;
      transition: border-color 0.2s, color 0.2s;
    }
    .social-icon:hover { border-color: var(--gold); color: var(--gold); }

    .overlay-legal {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      color: #999;
      letter-spacing: 0.05em;
      text-align: right;
    }

    .overlay-legal a { color: #999; text-decoration: none; }
    .overlay-legal a:hover { color: var(--gold); }

    /* ── SECTION BELOW HERO ── */
    .section-featured {
      min-height: 100vh;
      background: var(--dark);
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 6rem 3rem;
    }

    /* Keep body scrollable when overlay is closed */
    body.no-scroll { overflow: hidden; }
    body.scrollable { overflow-y: auto; }

    /* back to demo link */
    .back-link {
      position: fixed;
      bottom: 1.5rem;
      left: 2.5rem;
      z-index: 300;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gray-light);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: color 0.2s, border-color 0.2s;
    }
    .back-link:hover { color: var(--gold); border-color: var(--gold); }

    @media (max-width: 1024px) {
      nav {
        padding: 1rem 1.2rem;
        min-height: 74px;
      }

      .logo-image { width: min(250px, 46vw); }

      .hero {
        margin-top: 74px;
        height: calc(100vh - 74px);
        grid-template-columns: 1fr;
      }

      .hero-image { min-height: 38vh; }

      .hero-content {
        padding: 2rem 1.4rem 2.5rem;
        justify-content: flex-start;
      }

      .hero-title { max-width: none; }

      .carousel-bar {
        position: static;
        padding: 1rem 1.2rem 1.4rem;
        gap: 0.7rem;
        flex-wrap: wrap;
        background: var(--dark);
      }

      .back-link {
        position: static;
        display: inline-block;
        margin: 0 1.2rem 1.2rem;
      }

      .overlay-top,
      .overlay-nav,
      .overlay-footer {
        padding-left: 1.2rem;
        padding-right: 1.2rem;
      }

      .overlay-nav {
        align-items: flex-start;
        justify-content: flex-start;
        padding-top: 1rem;
        gap: 0.25rem;
      }

      .overlay-nav a {
        font-size: clamp(1.35rem, 6vw, 2.2rem);
      }

      .overlay-footer {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
      }

      .overlay-legal { text-align: left; }
    }

    @media (max-width: 720px) {
      .nav-left { display: none; }

      .logo {
        position: static;
        margin-right: auto;
      }

      .logo-image { width: min(200px, 52vw); }

      .nav-right { gap: 0.5rem; }

      .template-switch {
        font-size: 0.5rem;
        letter-spacing: 0.14em;
        padding: 0.4rem 0.5rem;
      }

      .menu-label { display: none; }

      .hero-image { min-height: 30vh; }

      .hero-content {
        padding: 1.4rem 1rem 1.8rem;
      }

      .hero-eyebrow {
        font-size: 0.52rem;
        letter-spacing: 0.25em;
      }

      .hero-title {
        font-size: clamp(1.45rem, 8vw, 2.1rem);
      }

      .carousel-dots { order: 1; }
      .more-news { order: 2; }

      .carousel-tabs { width: 100%; }

      .carousel-tab {
        flex: 1 1 auto;
        text-align: center;
        font-size: 0.53rem;
      }
    }

    @media (max-height: 760px) and (orientation: landscape) {
      nav {
        min-height: 66px;
        padding-top: 0.7rem;
        padding-bottom: 0.7rem;
      }

      .hero {
        margin-top: 66px;
        height: auto;
      }

      .hero-image { min-height: 48vh; }

      .hero-content {
        padding: 1rem 1.2rem 1.2rem;
      }

      .carousel-bar {
        padding-top: 0.8rem;
        padding-bottom: 1rem;
      }
    }
  </style>
</head>
<body class="no-scroll">

  <!-- MENU OVERLAY -->
