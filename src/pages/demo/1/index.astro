    <svg class="overlay-bg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
      <g fill="none" stroke="rgba(0,0,0,0.07)" stroke-width="1">
        <!-- Topo lines generated as gentle waves -->
        <path d="M-100,150 C200,120 400,180 700,140 S1100,100 1540,160"/>
        <path d="M-100,200 C180,165 420,235 720,190 S1120,145 1540,210"/>
        <path d="M-100,260 C200,225 380,290 680,250 S1080,200 1540,270"/>
        <path d="M-100,320 C220,285 400,350 700,305 S1100,255 1540,325"/>
        <path d="M-100,385 C200,345 420,415 720,370 S1120,315 1540,390"/>
        <path d="M-100,450 C200,410 380,480 680,430 S1080,380 1540,455"/>
        <path d="M-100,520 C220,475 400,550 700,500 S1100,445 1540,525"/>
        <path d="M-100,590 C200,545 420,620 720,565 S1120,510 1540,595"/>
        <path d="M-100,660 C200,615 380,690 680,635 S1080,580 1540,665"/>
