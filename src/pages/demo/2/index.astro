<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Demo 2 — Marinescu & Asociații</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #C9A55A;
      --gold-dark: #A8833A;
      --teal: #173628;
      --teal-mid: #1F4A35;
      --teal-light: #2A6248;
      --dark: #0F211A;
      --off-white: #F4EFE5;
      --body-bg: #FAFAF8;
      --text: #1A1A18;
      --gray: #6A6A66;
      --border: rgba(201,165,90,0.2);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Georgia', serif;
      background: var(--body-bg);
      color: var(--text);
    }

    /* ── HEADER ── */
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: #fff;
      border-bottom: 1px solid #E8E4DC;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.9rem 2.5rem;
      gap: 1rem;
    }

    .header-logo {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      text-decoration: none;
      flex-shrink: 0;
    }

    .logo-mark {
      width: 38px; height: 38px;
      background: var(--teal);
      display: flex; align-items: center; justify-content: center;
      clip-path: polygon(50% 0%, 100% 100%, 0% 100%);
      flex-shrink: 0;
    }

    .logo-mark span {
      color: var(--gold);
      font-size: 0.85rem;
      font-weight: 700;
      margin-top: 8px;
    }

    .logo-text-wrap { display: flex; flex-direction: column; }

    .logo-text-main {
      font-family: 'Helvetica Neue', sans-serif;
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
      color: var(--text);
      text-transform: uppercase;
    }

    .logo-text-sub {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gray);
    }

    .header-nav {
      display: flex;
      align-items: center;
      gap: 2rem;
      list-style: none;
    }

    .header-nav a {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.8rem;
      color: var(--text);
      text-decoration: none;
      letter-spacing: 0.02em;
      transition: color 0.2s;
    }
    .header-nav a:hover { color: var(--teal); }

    .cta-btn {
      background: var(--teal);
      color: var(--off-white) !important;
      padding: 0.6rem 1.3rem;
      border-radius: 2px;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.78rem;
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: background 0.2s;
      display: flex; align-items: center; gap: 0.4rem;
      white-space: nowrap;
    }
    .cta-btn:hover { background: var(--teal-mid) !important; }

    .template-switch {
      border: 1px solid rgba(23,54,40,0.25);
      text-decoration: none;
      color: var(--teal);
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.68rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 0.55rem 0.8rem;
      white-space: nowrap;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
    }

    .template-switch:hover {
      background: var(--teal);
      color: #fff;
      border-color: var(--teal);
    }

    /* Mobile hamburger */
    .hamburger {
      display: none;
      background: none; border: none; cursor: pointer;
      flex-direction: column; gap: 5px;
    }
    .hamburger span {
      display: block; width: 22px; height: 2px;
      background: var(--text);
    }

    @media (max-width: 768px) {
      .header-nav { display: none; }
      .hamburger { display: flex; }
      .template-switch { font-size: 0.6rem; padding: 0.5rem 0.65rem; }
    }

    /* ── HERO SECTION ── */
    .hero {
      background: var(--teal);
      min-height: calc(100vh - 60px);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      padding: 5rem 2rem 6rem;
    }

    /* Subtle geometric watermark */
    .hero::before {
      content: 'M';
      position: absolute;
      right: -2%;
      bottom: -5%;
      font-size: 35vw;
      font-weight: 700;
      color: rgba(255,255,255,0.03);
      font-family: 'Georgia', serif;
      line-height: 1;
      pointer-events: none;
      user-select: none;
    }

    /* Abstract diagonal lines */
    .hero-lines {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .hero-content {
      text-align: center;
      max-width: 750px;
      position: relative;
      z-index: 1;
    }

    .hero-eyebrow {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 2rem;
    }

    .hero-title {
      font-size: clamp(2rem, 5.5vw, 3.8rem);
      font-style: italic;
      font-weight: 400;
      line-height: 1.2;
      color: #fff;
      margin-bottom: 1.5rem;
    }

    .hero-sub {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.85rem;
      line-height: 1.8;
      color: rgba(255,255,255,0.65);
      margin-bottom: 0.5rem;
    }

    .hero-tagline {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.75rem;
      color: rgba(255,255,255,0.4);
      letter-spacing: 0.05em;
      margin-bottom: 3rem;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border: 1.5px solid rgba(255,255,255,0.8);
      color: #fff;
      padding: 0.75rem 2rem;
      text-decoration: none;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      transition: background 0.2s, color 0.2s;
    }
    .hero-cta:hover { background: rgba(255,255,255,0.1); }

    /* ── MANIFESTO BAND ── */
    .manifesto {
      background: var(--body-bg);
      padding: 5rem 2rem;
      text-align: center;
    }

    .manifesto blockquote {
      max-width: 680px;
      margin: 0 auto;
      font-size: clamp(1.1rem, 2.5vw, 1.55rem);
      font-style: italic;
      line-height: 1.6;
      color: var(--teal);
    }

    /* ── STATS ── */
    .stats {
      background: var(--body-bg);
      padding: 2rem 2rem 5rem;
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      text-align: center;
    }

    @media (max-width: 580px) {
      .stats { grid-template-columns: 1fr; }
    }

    .stat-num {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      color: var(--teal);
      font-family: 'Georgia', serif;
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .stat-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text);
      margin-bottom: 0.2rem;
    }

    .stat-desc {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.7rem;
      color: var(--gold);
      letter-spacing: 0.05em;
    }

    /* ── CONTACT SECTION ── */
    #contact {
      display: grid;
      grid-template-columns: 5fr 6fr;
      min-height: 480px;
    }

    @media (max-width: 720px) {
      #contact { grid-template-columns: 1fr; }
    }

    .contact-left {
      background: var(--teal);
      padding: 4rem 3rem;
      color: #fff;
    }

    .contact-left h2 {
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 400;
      line-height: 1.25;
      margin-bottom: 1.5rem;
    }

    .contact-left p {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.85rem;
      line-height: 1.8;
      color: rgba(255,255,255,0.75);
      margin-bottom: 2rem;
    }

    .contact-info { display: flex; flex-direction: column; gap: 1.2rem; }

    .contact-info-item {}

    .contact-info-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.3rem;
    }

    .contact-info-val {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.85rem;
      color: #fff;
    }

    .offices { display: flex; gap: 2.5rem; margin-top: 0.3rem; }

    .contact-right {
      background: #fff;
      padding: 4rem 3rem;
    }

    .form-group { margin-bottom: 1.2rem; }

    label {
      display: block;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      color: var(--text);
      margin-bottom: 0.4rem;
    }

    input, select, textarea {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1px solid #E0DDD6;
      background: #F7F5F0;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.82rem;
      color: var(--text);
      outline: none;
      transition: border-color 0.2s;
      appearance: none;
      border-radius: 0;
    }
    input:focus, select:focus, textarea:focus {
      border-color: var(--teal);
    }
    input::placeholder, textarea::placeholder {
      color: #B0ADA6;
    }

    textarea { min-height: 100px; resize: vertical; }

    .submit-btn {
      width: 100%;
      padding: 0.9rem;
      background: #1A1A18;
      color: #fff;
      border: none;
      cursor: pointer;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.82rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: background 0.2s;
    }
    .submit-btn:hover { background: var(--teal); }

    /* ── FOOTER ── */
    footer {
      background: var(--dark);
      color: rgba(255,255,255,0.4);
      padding: 2rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    footer .f-brand {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.6);
    }

    footer .f-links { display: flex; gap: 1.5rem; flex-wrap: wrap; }

    footer a {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.35);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    footer a:hover { color: var(--gold); }

    /* back to demo */
    .back-link {
      position: fixed;
      bottom: 1.5rem; left: 2rem;
      z-index: 200;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      background: rgba(23,54,40,0.9);
      color: var(--gold);
      padding: 0.5rem 0.9rem;
      text-decoration: none;
      border: 1px solid rgba(201,165,90,0.3);
      transition: background 0.2s;
    }
    .back-link:hover { background: var(--teal); }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header>
    <a href="/demo/2" class="header-logo">
      <div class="logo-mark"><span>M</span></div>
      <div class="logo-text-wrap">
        <span class="logo-text-main">Marinescu &amp; Asociații</span>
        <span class="logo-text-sub">Attorneys at Law</span>
      </div>
    </a>

    <nav>
      <ul class="header-nav">
        <li><a href="#acasa">Acasă</a></li>
        <li><a href="#servicii">Servicii</a></li>
        <li><a href="#avocati">Avocații Noștri</a></li>
        <li><a href="#noutati">Blog</a></li>
        <li><a href="#pro-bono">Pro Bono</a></li>
        <li>
          <a href="#contact" class="cta-btn">Contactați-ne →</a>
        </li>
      </ul>
      <button class="hamburger" aria-label="Meniu">
        <span></span><span></span><span></span>
      </button>
    </nav>

    <a href="/demo/1" class="template-switch" aria-label="Comută la Template 1">Template 1</a>
  </header>

  <!-- HERO -->
  <section class="hero" id="acasa">
    <svg class="hero-lines" viewBox="0 0 1440 700" preserveAspectRatio="xMidYMid slice">
      <g fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1">
        <line x1="0" y1="700" x2="1440" y2="0"/>
        <line x1="200" y1="700" x2="1440" y2="100"/>
        <line x1="400" y1="700" x2="1440" y2="200"/>
        <line x1="0" y1="500" x2="1200" y2="0"/>
        <line x1="0" y1="300" x2="900" y2="0"/>
      </g>
    </svg>

    <div class="hero-content">
      <p class="hero-eyebrow">Litigii Comerciale</p>
      <h1 class="hero-title">
        Analiză condusă de seniori.<br />
        Construită pentru litigii complexe.
      </h1>
      <p class="hero-sub">Avocatul care înțelege cazul dumneavoastră este cel care lucrează pentru dumneavoastră.</p>
      <p class="hero-tagline">Fără analiști juniori. Fără predare. Fără compromisuri.</p>
      <a href="#contact" class="hero-cta">Contactați-ne →</a>
    </div>
  </section>

  <!-- MANIFESTO BAND -->
  <section class="manifesto" id="servicii">
    <blockquote>
      "Implicare la nivel de senior în fiecare dosar.<br />
      Analiza urmează cazul, nu un șablon."
    </blockquote>
  </section>

  <!-- STATS -->
  <div class="stats">
    <div>
      <div class="stat-num">500M+</div>
      <div class="stat-label">RON Litigii</div>
      <div class="stat-desc">Valoare dosare gestionate</div>
    </div>
    <div>
      <div class="stat-num">30+</div>
      <div class="stat-label">Ani Experiență</div>
      <div class="stat-desc">Experiență cumulată echipă</div>
    </div>
    <div>
      <div class="stat-num">98%</div>
      <div class="stat-label">Rată de Succes</div>
      <div class="stat-desc">Dosare câștigate sau soluționate favorabil</div>
    </div>
  </div>

  <!-- CONTACT SECTION -->
  <section id="contact">
    <div class="contact-left">
      <h2>Să discutăm<br />dosarul dvs.</h2>
      <p>Echipa noastră este disponibilă pentru o consultație referitoare la nevoile dvs. de litigii comerciale.</p>
      <div class="contact-info">
        <div class="contact-info-item">
          <p class="contact-info-label">Email</p>
          <p class="contact-info-val">contact@sca-marinescu.ro</p>
        </div>
        <div class="contact-info-item">
          <p class="contact-info-label">Urgențe</p>
          <p class="contact-info-val">+40 21 000 0000</p>
        </div>
        <div class="contact-info-item">
          <p class="contact-info-label">Birouri</p>
          <div class="offices">
            <span class="contact-info-val">București</span>
            <span class="contact-info-val">Cluj-Napoca</span>
          </div>
        </div>
      </div>
    </div>

    <div class="contact-right">
      <form>
        <div class="form-group">
          <label for="name">Nume</label>
          <input type="text" id="name" placeholder="Ion Popescu" autocomplete="name" />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" placeholder="ion@companie.ro" autocomplete="email" />
        </div>
        <div class="form-group">
          <label for="company">Companie / Casă de avocatură</label>
          <input type="text" id="company" placeholder="Compania SRL" />
        </div>
        <div class="form-group">
          <label for="matter">Tipul dosarului</label>
          <select id="matter">
            <option value="">Selectați...</option>
            <option>Litigii Comerciale</option>
            <option>Arbitraj Internațional</option>
            <option>Recuperare Creanțe</option>
            <option>Insolventă & Restructurare</option>
            <option>Altele</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Mesaj</label>
          <textarea id="message" placeholder="Descrieți pe scurt situația dvs..."></textarea>
        </div>
        <button type="submit" class="submit-btn">Trimiteți</button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <span class="f-brand">Societatea Civilă de Avocatură Marinescu &amp; Asociații &copy; 2026</span>
    <div class="f-links">
      <a href="#">Politică de Confidențialitate</a>
      <a href="#">Termeni &amp; Condiții</a>
      <a href="#">Publicitate Juridică</a>
    </div>
  </footer>

  <a href="/demo" class="back-link">← Demo selector</a>

</body>
</html>
