<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Demo Selector — Marinescu & Asociații</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #C9A55A;
      --gold-light: #E2C07A;
      --dark: #141210;
      --dark-2: #1E1B18;
      --off-white: #F5F0E8;
      --gray: #888880;
    }

    body {
      font-family: 'Georgia', serif;
      background: var(--dark);
      color: var(--off-white);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    header {
      position: fixed;
      top: 0; left: 0; right: 0;
      padding: 1.5rem 3rem;
      display: flex;
      align-items: center;
      justify-content: center;
      border-bottom: 1px solid rgba(201,165,90,0.15);
    }

    .template-switch {
      position: absolute;
      right: 3rem;
      top: 50%;
      transform: translateY(-50%);
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--gold);
      border: 1px solid rgba(201,165,90,0.35);
      padding: 0.45rem 0.7rem;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
      white-space: nowrap;
    }

    .template-switch:hover {
      border-color: var(--gold-light);
      color: var(--off-white);
      background: rgba(201,165,90,0.12);
    }

    .brand {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
      text-decoration: none;
    }

    .brand-monogram {
      font-size: 2rem;
      font-weight: 700;
      color: var(--gold);
      letter-spacing: 0.05em;
      line-height: 1;
    }

    .brand-name {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--off-white);
    }

    main {
      text-align: center;
      padding: 8rem 2rem 4rem;
      max-width: 900px;
      width: 100%;
    }

    .eyebrow {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
    }

    h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 400;
      line-height: 1.15;
      margin-bottom: 1rem;
      color: var(--off-white);
    }

    .subtitle {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.9rem;
      color: var(--gray);
      margin-bottom: 4rem;
      line-height: 1.7;
    }

    .demos {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    @media (max-width: 600px) {
      .demos { grid-template-columns: 1fr; }

      header {
        padding: 1rem 1rem;
        justify-content: flex-start;
      }

      .template-switch {
        right: 1rem;
        font-size: 0.52rem;
      }

      .brand {
        align-items: flex-start;
      }

      .brand-name {
        letter-spacing: 0.18em;
      }
    }

    .demo-card {
      background: var(--dark-2);
      border: 1px solid rgba(201,165,90,0.2);
      text-decoration: none;
      display: block;
      overflow: hidden;
      transition: border-color 0.3s, transform 0.3s;
    }

    .demo-card:hover {
      border-color: var(--gold);
      transform: translateY(-3px);
    }

    .demo-preview {
      height: 200px;
      display: flex;
      align-items: flex-end;
      padding: 1.5rem;
      position: relative;
      overflow: hidden;
    }

    /* Demo 1 preview — dark editorial */
    .demo-card:nth-child(1) .demo-preview {
      background: #0D0D0D;
    }

    .demo-card:nth-child(1) .demo-preview::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg,
        #1a2e3a 0%, #0a1520 40%, #0D0D0D 100%);
      opacity: 0.7;
    }

    /* Abstract lines decoration for D1 */
    .demo-card:nth-child(1) .demo-preview::after {
      content: '';
      position: absolute;
      left: 0; top: 0;
      width: 50%;
      height: 100%;
      background: repeating-linear-gradient(
        160deg,
        rgba(180,220,240,0.06) 0px,
        rgba(180,220,240,0.06) 1px,
        transparent 1px,
        transparent 14px
      );
    }

    /* Demo 2 preview — teal/charcoal */
    .demo-card:nth-child(2) .demo-preview {
      background: #162820;
    }

    .demo-card:nth-child(2) .demo-preview::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(160deg, #1C3D2E 0%, #0E2318 100%);
    }

    .preview-label {
      position: relative;
      z-index: 1;
    }

    .preview-label .tag {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.4rem;
    }

    .preview-label h2 {
      font-size: 1.1rem;
      font-weight: 400;
      color: #fff;
      line-height: 1.3;
    }

    .demo-card-footer {
      padding: 1rem 1.5rem;
      border-top: 1px solid rgba(201,165,90,0.1);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .demo-card-footer span {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gray);
    }

    .arrow {
      color: var(--gold);
      font-size: 1rem;
      transition: transform 0.2s;
    }

    .demo-card:hover .arrow { transform: translateX(4px); }

    footer {
      padding: 2rem;
      text-align: center;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      color: var(--gray);
      text-transform: uppercase;
    }
  </style>
</head>
<body>
  <header>
    <div class="brand">
      <span class="brand-monogram">M &amp; A</span>
      <span class="brand-name">Marinescu &amp; Asociații · Attorneys at Law</span>
    </div>

    <a id="templateSwitch" class="template-switch" href="/demo/1" aria-label="Schimbă template-ul">Switch to Template 1</a>
  </header>

  <main>
    <p class="eyebrow">Demo Preview</p>
    <h1>Alegeți un template<br />de prezentare</h1>
    <p class="subtitle">
      Două direcții vizuale pentru sca-marinescu.ro.<br />
      Selectați varianta dorită pentru a o vizualiza.
    </p>

    <div class="demos">
      <a href="/demo/1" class="demo-card">
        <div class="demo-preview">
          <div class="preview-label">
            <p class="tag">Demo 1 · Editorial Întunecat</p>
            <h2>Litigii Comerciale<br />de Anvergură</h2>
          </div>
        </div>
        <div class="demo-card-footer">
          <span>Inspirat din Kirkland &amp; Ellis</span>
          <span class="arrow">→</span>
        </div>
      </a>

      <a href="/demo/2" class="demo-card">
        <div class="demo-preview">
          <div class="preview-label">
            <p class="tag">Demo 2 · Verde Elegant</p>
            <h2>Analiză Condusă<br />de Seniori</h2>
          </div>
        </div>
        <div class="demo-card-footer">
          <span>Inspirat din Verdict Consulting</span>
          <span class="arrow">→</span>
        </div>
      </a>
    </div>
  </main>

  <footer>
    &copy; 2026 Societatea Civilă de Avocatură Marinescu &amp; Asociații
  </footer>

  <script>
    /** @type {HTMLAnchorElement | null} */
    const switchBtn = document.getElementById('templateSwitch');
    const nextTemplate = localStorage.getItem('demoNextTemplate') === '2' ? '2' : '1';

    function setSwitchTarget(templateId) {
      if (!switchBtn) return;
      switchBtn.setAttribute('href', `/demo/${templateId}`);
      switchBtn.textContent = templateId === '1' ? 'Switch to Template 1' : 'Switch to Template 2';
    }

    setSwitchTarget(nextTemplate);

    if (switchBtn) {
      switchBtn.addEventListener('click', () => {
        const upcomingTemplate = nextTemplate === '1' ? '2' : '1';
        localStorage.setItem('demoNextTemplate', upcomingTemplate);
      });
    }
  </script>
</body>
</html>
