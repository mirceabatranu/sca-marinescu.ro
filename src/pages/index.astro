    <script>
      const overlay = document.getElementById('overlay');
      const menuBtn = document.getElementById('menuBtn');
      const closeBtn = document.getElementById('closeBtn');

      function openOverlay() {
        overlay.classList.add('open');
        menuBtn.setAttribute('aria-expanded', 'true');
        document.body.classList.remove('no-scroll');
      }

      function closeOverlay() {
        overlay.classList.remove('open');
        menuBtn.setAttribute('aria-expanded', 'false');
      }

      menuBtn.addEventListener('click', openOverlay);
      closeBtn.addEventListener('click', closeOverlay);

      overlay.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeOverlay();
      });

      const tabButtons = document.querySelectorAll('.carousel-tab');
      const prevSlide = document.getElementById('prevSlide');
      const nextSlide = document.getElementById('nextSlide');

      let activeIndex = 0;

      /** @param {number} index */
      function renderSlide(index) {
        activeIndex = index;
        tabButtons.forEach((btn, btnIndex) => {
          const isActive = btnIndex === index;
          btn.classList.toggle('active', isActive);
          btn.setAttribute('aria-selected', String(isActive));
        });
      }

      tabButtons.forEach((btn, index) => {
        btn.addEventListener('click', () => renderSlide(index));
      });

      prevSlide.addEventListener('click', () => {
        const newIndex = (activeIndex - 1 + tabButtons.length) % tabButtons.length;
        renderSlide(newIndex);
      });

      nextSlide.addEventListener('click', () => {
        const newIndex = (activeIndex + 1) % tabButtons.length;
        renderSlide(newIndex);
      });

      renderSlide(0);
    </script>
