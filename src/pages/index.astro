<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Litigii comerciale in Romania | SCA Marinescu</title>
  <meta name="description" content="SCA Marinescu — societate civila de avocatura specializata in litigii comerciale, arbitraj si dispute corporative in Romania." />
  <link rel="canonical" href="https://sca-marinescu.ro/" />
  <link rel="alternate" href="https://sca-marinescu.ro/" hreflang="ro-RO" />
  <link rel="alternate" href="https://sca-marinescu.ro/en/" hreflang="en" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #C9A55A;
      --gold-dim: rgba(201,165,90,0.4);
      --dark: #0E0D0C;
      --dark-nav: #131210;
      --off-white: #F0EBE0;
      --gray: #6B6860;
      --gray-light: #9A9590;
    }

    html, body { height: 100%; }

    body {
      font-family: 'Georgia', serif;
      background: var(--dark);
      color: var(--off-white);
    }

    /* ── TOPBAR ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 300;
      display: flex;
      align-items: center;
      padding: 1.4rem 2.5rem;
      min-height: 86px;
      background: var(--dark-nav);
      border-bottom: 1px solid rgba(201,165,90,0.12);
    }

    /* Logo — left side */
    .logo {
      text-align: center;
      text-decoration: none;
      background: var(--dark-nav);
      border: 1px solid rgba(201,165,90,0.28);
      padding: 0.4rem 0.65rem;
      flex-shrink: 0;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .logo-image {
      display: block;
      width: 260px;
      max-width: 38vw;
      height: auto;
    }

    /* Nav controls — far right */
    .nav-right {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-left: auto;
    }

    .lang-switch {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.56rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--gold);
      border: 1px solid rgba(201,165,90,0.35);
      padding: 0.45rem 0.7rem;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
      white-space: nowrap;
    }

    .lang-switch:hover {
      color: var(--off-white);
      border-color: var(--gold);
      background: rgba(201,165,90,0.12);
    }

    .menu-btn {
      background: none; border: none; cursor: pointer;
      display: flex; flex-direction: column;
      align-items: flex-end;
      gap: 4px;
      padding: 0.3rem;
    }

    .menu-btn span {
      display: block;
      height: 1.5px;
      background: var(--gold);
      transition: width 0.2s;
    }
    .menu-btn span:nth-child(1) { width: 22px; }
    .menu-btn span:nth-child(2) { width: 16px; }
    .menu-btn span:nth-child(3) { width: 22px; }

    .menu-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.5rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-top: 0.3rem;
    }

    .menu-btn-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      cursor: pointer;
      background: none;
      border: none;
    }

    /* Logo slides left when menu opens — desktop only */
    @media (min-width: 901px) {
      nav.menu-open .logo {
        transform: translateX(-2rem);
      }
    }

    /* ── BACKDROP ── */
    .overlay-backdrop {
      position: fixed;
      inset: 0;
      z-index: 199;
      background: rgba(0, 0, 0, 0.55);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.4s ease;
    }

    .overlay-backdrop.visible {
      opacity: 1;
      pointer-events: all;
    }

    /* ── MENU OVERLAY — 40% slide-in from right ── */
    .overlay {
      position: fixed;
      top: 0;
      right: 0;
      width: 40%;
      height: 100vh;
      z-index: 200;
      background: #0E0D0C;
      display: flex;
      flex-direction: column;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      overflow-y: auto;
      overflow-x: hidden;
      border-left: 1px solid rgba(201,165,90,0.14);
    }

    .overlay.open {
      transform: translateX(0);
    }

    .overlay-top {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 1.6rem 2rem;
      flex-shrink: 0;
    }

    .close-btn {
      background: none; border: none; cursor: pointer;
      display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
      color: var(--off-white);
      transition: color 0.2s;
    }

    .close-btn:hover { color: var(--gold); }

    .close-btn svg { stroke: currentColor; stroke-width: 1.5; }

    .close-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.5rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: inherit;
    }

    /* Nav links — white text, gold on hover */
    .overlay-nav {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding: 1rem 3rem;
      gap: 0.4rem;
    }

    .overlay-nav a {
      font-size: clamp(1.6rem, 2.8vw, 2.4rem);
      font-weight: 400;
      text-decoration: none;
      color: var(--off-white);
      line-height: 1.35;
      transition: color 0.2s;
      font-family: 'Georgia', serif;
    }

    .overlay-nav a:hover {
      color: var(--gold);
    }

    .overlay-footer {
      display: flex;
      align-items: flex-end;
      justify-content: flex-end;
      padding: 1.5rem 2rem;
      flex-shrink: 0;
      border-top: 1px solid rgba(201,165,90,0.1);
    }

    .overlay-legal {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.58rem;
      color: rgba(240, 235, 224, 0.42);
      letter-spacing: 0.05em;
      text-align: right;
      line-height: 1.6;
    }

    .overlay-legal a { color: rgba(240, 235, 224, 0.42); text-decoration: none; }
    .overlay-legal a:hover { color: var(--gold); }

    /* ── HERO ── */
    .hero {
      height: calc(100vh - 86px);
      margin-top: 86px;
      display: grid;
      grid-template-columns: 45% 55%;
    }

    /* Left: abstract wave image */
    .hero-image {
      position: relative;
      overflow: hidden;
    }

    .hero-image-panel {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 2.2rem;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 1.4rem;
    }

    /* SVG wave lines */
    .hero-image svg {
      width: 100%; height: 100%;
      position: absolute; inset: 0;
    }

    /* Right: content panel */
    .hero-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 2rem 3rem;
      background: var(--dark);
    }

    .hero-eyebrow {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .hero-title {
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 400;
      line-height: 1.18;
      color: var(--off-white);
      margin-bottom: 1rem;
      max-width: 460px;
    }

    .hero-detail-title {
      font-size: clamp(1.35rem, 2.4vw, 2rem);
      line-height: 1.25;
      color: var(--off-white);
      margin-bottom: 1rem;
      max-width: 520px;
    }

    .hero-summary {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.9rem;
      line-height: 1.75;
      color: rgba(240,235,224,0.72);
      max-width: 540px;
    }

    .carousel-inline {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      column-gap: 1rem;
      row-gap: 0.45rem;
      width: min(100%, 520px);
      margin-top: 1rem;
    }

    .carousel-tabs {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .carousel-arrow {
      background: none; border: none; cursor: pointer;
      color: var(--gold); font-size: 1.1rem;
    }

    .carousel-tab {
      border: none;
      background: transparent;
      color: var(--gray-light);
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 0.2rem 0.25rem 0.62rem;
      cursor: pointer;
      position: relative;
      transition: color 0.2s;
    }

    .carousel-tab::after {
      content: '';
      position: absolute;
      left: 0; right: 0; bottom: 0;
      height: 2px;
      background: var(--gray);
      transition: background 0.2s, height 0.2s;
    }

    .carousel-tab.active { color: var(--off-white); }
    .carousel-tab.active::after { height: 3px; background: var(--off-white); }
    .carousel-tab:hover { color: var(--off-white); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      /* Full-width overlay on mobile */
      .overlay {
        width: 100%;
        border-left: none;
      }

      .overlay-nav {
        align-items: flex-start;
        padding: 1rem 2rem;
      }

      .overlay-footer {
        justify-content: flex-start;
      }

      .overlay-legal { text-align: left; }
    }

    @media (max-width: 1024px) {
      nav {
        padding: 1rem 1.2rem;
        min-height: 74px;
      }

      .logo-image { width: 220px; max-width: 40vw; }

      .hero {
        margin-top: 74px;
        height: calc(100vh - 74px);
        grid-template-columns: 1fr;
      }

      .hero-image { min-height: 38vh; }

      .hero-image-panel { bottom: 1.4rem; }

      .hero-content {
        padding: 2rem 1.4rem 2.5rem;
      }

      .hero-title { max-width: none; }

      .overlay-nav {
        padding-left: 1.5rem;
        padding-right: 1.5rem;
      }

      .overlay-footer {
        padding-left: 1.5rem;
        padding-right: 1.5rem;
      }
    }

    @media (max-width: 720px) {
      .logo-image { width: min(180px, 44vw); }
      .lang-switch { font-size: 0.5rem; letter-spacing: 0.14em; padding: 0.4rem 0.5rem; }
      .menu-label { display: none; }
      .hero-image { min-height: 30vh; }
      .hero-content { padding: 1.4rem 1rem 1.8rem; }
      .hero-image-panel { bottom: 1rem; padding: 0 1rem; }
      .hero-eyebrow { font-size: 0.52rem; letter-spacing: 0.25em; }
      .hero-title { font-size: clamp(1.45rem, 8vw, 2.1rem); }
      .carousel-inline { width: 100%; column-gap: 0.45rem; }
      .carousel-tabs { width: 100%; }
      .carousel-tab { flex: 1 1 30%; text-align: center; font-size: 0.53rem; }
    }

    @media (max-height: 760px) and (orientation: landscape) {
      nav {
        min-height: 66px;
        padding-top: 0.7rem;
        padding-bottom: 0.7rem;
      }

      .hero {
        margin-top: 66px;
        height: auto;
      }

      .hero-image { min-height: 48vh; }

      .hero-content {
        padding: 1rem 1.2rem 1.2rem;
      }
    }
  </style>
</head>
<body>

  <!-- BACKDROP -->
  <div class="overlay-backdrop" id="overlayBackdrop"></div>

  <!-- MENU OVERLAY PANEL -->
  <div class="overlay" id="overlay" role="dialog" aria-modal="true" aria-label="Meniu principal">
    <div class="overlay-top">
      <button class="close-btn" id="closeBtn" aria-label="Închide meniu">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <line x1="2" y1="2" x2="20" y2="20"/>
          <line x1="20" y1="2" x2="2" y2="20"/>
        </svg>
        <span class="close-label">Închide</span>
      </button>
    </div>

    <nav class="overlay-nav">
      <a href="#services" onclick="closeOverlay()">Practică</a>
      <a href="#approach" onclick="closeOverlay()">Abordare</a>
      <a href="#matters" onclick="closeOverlay()">Mandate</a>
      <a href="#insights" onclick="closeOverlay()">Întrebări</a>
      <a href="#contact" onclick="closeOverlay()">Contact</a>
    </nav>

    <footer class="overlay-footer">
      <div class="overlay-legal">
        &copy; 2026 Societatea Civilă de Avocatură Marinescu &amp; Asociații
      </div>
    </footer>
  </div>

  <!-- TOPBAR -->
  <nav id="mainNav">
    <a href="/" class="logo">
      <img src="/company-logo-gold.svg" alt="Marinescu &amp; Asociații" class="logo-image" />
    </a>

    <div class="nav-right">
      <a href="/en/" class="lang-switch" hreflang="en" aria-label="English version">EN</a>

      <button class="menu-btn-wrap" id="menuBtn" aria-label="Deschide meniu" aria-expanded="false">
        <div class="menu-btn">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <span class="menu-label">Meniu</span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <div class="hero">
    <!-- Left abstract wave panel -->
    <div class="hero-image">
      <svg viewBox="0 0 640 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="waveBg" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#1A3040"/>
            <stop offset="50%" stop-color="#0E2030"/>
            <stop offset="100%" stop-color="#060E14"/>
          </linearGradient>
          <linearGradient id="waveShine" x1="20%" y1="0%" x2="80%" y2="100%">
            <stop offset="0%" stop-color="#A8D8F0" stop-opacity="0.6"/>
            <stop offset="40%" stop-color="#7AB8D8" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="#3A6080" stop-opacity="0"/>
          </linearGradient>
        </defs>
        <rect width="640" height="900" fill="url(#waveBg)"/>
        <g fill="none" stroke-width="0.8">
          <path d="M320,900 C300,750 260,600 320,450 S400,250 320,100 S200,-50 100,50" stroke="rgba(160,210,240,0.18)"/>
          <path d="M320,900 C295,745 250,590 315,440 S400,235 318,88 S193,-60 93,40" stroke="rgba(160,210,240,0.16)"/>
          <path d="M320,900 C288,738 242,578 310,428 S402,220 316,76 S186,-70 86,30" stroke="rgba(160,210,240,0.14)"/>
          <path d="M320,900 C280,730 234,566 304,416 S404,204 314,64 S178,-80 78,20" stroke="rgba(160,210,240,0.12)"/>
          <path d="M320,900 C272,722 226,554 298,404 S406,188 312,52 S171,-90 71,10" stroke="rgba(160,210,240,0.10)"/>
          <path d="M320,900 C264,714 218,542 292,392 S408,172 310,40 S164,-100 64,0" stroke="rgba(160,210,240,0.09)"/>
          <path d="M320,900 C256,706 210,530 286,380 S410,156 308,28 S157,-110 57,-10" stroke="rgba(160,210,240,0.08)"/>
          <path d="M320,900 C248,698 202,518 280,368 S412,140 306,16 S150,-120 50,-20" stroke="rgba(160,210,240,0.07)"/>
          <path d="M320,900 C240,690 194,506 274,356 S414,124 304,4 S143,-130 43,-30" stroke="rgba(160,210,240,0.06)"/>
          <path d="M320,900 C232,682 186,494 268,344 S416,108 302,-8 S136,-140 36,-40" stroke="rgba(160,210,240,0.05)"/>
          <!-- Bright highlight ribbons -->
          <path d="M320,900 C305,755 272,608 328,460 S398,262 326,112" stroke="rgba(190,230,250,0.35)"/>
          <path d="M320,900 C308,758 278,614 333,466 S396,268 329,118" stroke="rgba(190,230,250,0.28)"/>
          <path d="M320,900 C311,761 284,620 338,472 S394,274 332,124" stroke="rgba(190,230,250,0.20)"/>
          <path d="M320,900 C314,764 290,626 343,478 S392,280 335,130" stroke="rgba(190,230,250,0.14)"/>
        </g>
        <!-- Subtle gold accent line -->
        <path d="M320,900 C300,750 265,598 322,448 S401,248 322,98" fill="none" stroke="rgba(201,165,90,0.25)" stroke-width="1.5"/>
      </svg>

      <div class="hero-image-panel">
        <p class="hero-eyebrow">Practică de Excelență</p>
        <h1 class="hero-title">Soluții Strategice de Litigii Comerciale</h1>

        <div class="carousel-inline">
          <button class="carousel-arrow" id="prevSlide" aria-label="Anterior">&#8249;</button>
          <div class="carousel-tabs" role="tablist" aria-label="Categorii carousel">
            <button class="carousel-tab active" type="button" role="tab" aria-selected="true" data-slide="0">Servicii</button>
            <button class="carousel-tab" type="button" role="tab" aria-selected="false" data-slide="1">Clienți</button>
            <button class="carousel-tab" type="button" role="tab" aria-selected="false" data-slide="2">Litigii Comerciale</button>
          </div>
          <button class="carousel-arrow" id="nextSlide" aria-label="Următor">&#8250;</button>
        </div>
      </div>
    </div>

    <!-- Right content -->
    <div class="hero-content">
      <p class="hero-eyebrow" id="heroEyebrow">Servicii</p>
      <h2 class="hero-detail-title" id="heroTitle">Soluții Strategice de Litigii Comerciale</h2>
      <p class="hero-summary" id="heroSummary">Asistență în litigii contractuale, conflicte între acționari, arbitraj și executare, cu strategie procesuală construită pe miza comercială reală.</p>
    </div>
  </div>

  <script>
    const overlay = document.getElementById('overlay');
    const menuBtn = document.getElementById('menuBtn');
    const closeBtn = document.getElementById('closeBtn');
    const backdrop = document.getElementById('overlayBackdrop');
    const navEl = document.getElementById('mainNav');

    function openOverlay() {
      overlay.classList.add('open');
      backdrop.classList.add('visible');
      navEl.classList.add('menu-open');
      menuBtn.setAttribute('aria-expanded', 'true');
    }

    function closeOverlay() {
      overlay.classList.remove('open');
      backdrop.classList.remove('visible');
      navEl.classList.remove('menu-open');
      menuBtn.setAttribute('aria-expanded', 'false');
    }

    menuBtn.addEventListener('click', () => {
      if (overlay.classList.contains('open')) {
        closeOverlay();
      } else {
        openOverlay();
      }
    });

    closeBtn.addEventListener('click', closeOverlay);
    backdrop.addEventListener('click', closeOverlay);

    overlay.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeOverlay();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('open')) closeOverlay();
    });

    // Carousel controls
    const tabButtons = document.querySelectorAll('.carousel-tab');
    const prevSlide = document.getElementById('prevSlide');
    const nextSlide = document.getElementById('nextSlide');

    const slides = [
      {
        eyebrow: 'Servicii',
        title: 'Soluții Strategice de Litigii Comerciale',
        summary: 'Asistență în litigii contractuale, conflicte între acționari, arbitraj și executare, cu strategie procesuală construită pe miza comercială reală.',
      },
      {
        eyebrow: 'Clienți',
        title: 'Reprezentare pentru Companii și Grupuri Antreprenoriale',
        summary: 'Lucrăm cu societăți comerciale, grupuri de acționari și parteneri internaționali care au nevoie de claritate juridică în dispute cu miză ridicată.',
      },
      {
        eyebrow: 'Litigii Comerciale',
        title: 'Dispute Contractuale, Arbitraj și Recuperare de Creanțe',
        summary: 'Experiență în litigii complexe: neexecutare contractuală, blocaje societare, arbitraj instituțional și recuperarea creanțelor cu risc de disipare a activelor.',
      },
    ];

    let activeIndex = 0;

    /** @param {number} index */
    function renderSlide(index) {
      activeIndex = index;
      tabButtons.forEach((btn, btnIndex) => {
        const isActive = btnIndex === index;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-selected', String(isActive));
      });
      const slide = slides[index];
      document.getElementById('heroEyebrow').textContent = slide.eyebrow;
      document.getElementById('heroTitle').textContent = slide.title;
      document.getElementById('heroSummary').textContent = slide.summary;
    }

    tabButtons.forEach((btn, index) => {
      btn.addEventListener('click', () => renderSlide(index));
    });

    prevSlide.addEventListener('click', () => {
      const newIndex = (activeIndex - 1 + tabButtons.length) % tabButtons.length;
      renderSlide(newIndex);
    });

    nextSlide.addEventListener('click', () => {
      const newIndex = (activeIndex + 1) % tabButtons.length;
      renderSlide(newIndex);
    });

    renderSlide(0);
  </script>
</body>
</html>
