<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Litigii comerciale in Romania | SCA Marinescu</title>
  <meta name="description" content="SCA Marinescu — societate civila de avocatura specializata in litigii comerciale, arbitraj si dispute corporative in Romania." />
  <link rel="canonical" href="https://sca-marinescu.ro/" />
  <link rel="alternate" href="https://sca-marinescu.ro/" hreflang="ro-RO" />
  <link rel="alternate" href="https://sca-marinescu.ro/en/" hreflang="en" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #C9A55A;
      --dark: #0E0D0C;
      --dark-nav: #131210;
      --off-white: #F0EBE0;
      --gray: #6B6860;
      --gray-light: #9A9590;
      --nav-h: 130px; /* 98px logo + 2×16px padding */
    }

    html, body { height: 100%; overflow-x: hidden; }

    html { scroll-padding-top: var(--nav-h); }

    body {
      font-family: 'Georgia', serif;
      background: var(--dark);
      color: var(--off-white);
    }

    /* ── TOPBAR ── */
    nav#mainNav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 300;
      display: flex;
      align-items: center;
      padding: 1rem 2.5rem;
      min-height: var(--nav-h);
      background: var(--dark-nav);
      border-bottom: 1px solid rgba(201,165,90,0.12);
    }

    /* Logo — left side */
    .logo {
      text-decoration: none;
      flex-shrink: 0;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .logo-image {
      display: block;
      height: 98px;
      width: auto;
    }

    /* Nav controls — far right */
    .nav-right {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-left: auto;
    }

    .lang-switch {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.56rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--gold);
      border: 1px solid rgba(201,165,90,0.35);
      padding: 0.45rem 0.7rem;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
      white-space: nowrap;
    }

    .lang-switch:hover {
      color: var(--off-white);
      border-color: var(--gold);
      background: rgba(201,165,90,0.12);
    }

    .menu-btn-icon {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 4px;
    }

    .menu-btn-icon span {
      display: block;
      height: 1.5px;
      background: var(--gold);
    }
    .menu-btn-icon span:nth-child(1) { width: 22px; }
    .menu-btn-icon span:nth-child(2) { width: 16px; }
    .menu-btn-icon span:nth-child(3) { width: 22px; }

    .menu-btn-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.5rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-top: 0.3rem;
    }

    .menu-btn-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      cursor: pointer;
      background: none;
      border: none;
    }

    /* Logo slides left when menu opens — desktop only */
    @media (min-width: 901px) {
      nav#mainNav.menu-open .logo {
        transform: translateX(-2rem);
      }
    }

    /* ── BACKDROP ── */
    .overlay-backdrop {
      position: fixed;
      inset: 0;
      z-index: 199;
      background: rgba(0, 0, 0, 0.55);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.4s ease;
    }

    .overlay-backdrop.visible {
      opacity: 1;
      pointer-events: all;
    }

    /* ── MENU OVERLAY — 40% slide-in from right ── */
    .overlay {
      position: fixed;
      top: 0;
      right: 0;
      width: 40%;
      height: 100vh;
      z-index: 200;
      background: #0E0D0C;
      display: flex;
      flex-direction: column;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      overflow-y: auto;
      overflow-x: hidden;
      border-left: 1px solid rgba(201,165,90,0.14);
    }

    .overlay.open {
      transform: translateX(0);
    }

    .overlay-top {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 1.6rem 2rem;
      flex-shrink: 0;
    }

    .close-btn {
      background: none; border: none; cursor: pointer;
      display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
      color: var(--off-white);
      transition: color 0.2s;
    }

    .close-btn:hover { color: var(--gold); }
    .close-btn svg { stroke: currentColor; stroke-width: 1.5; }

    .close-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.5rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: inherit;
    }

    /* Nav links — white text, gold on hover */
    .overlay-nav {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding: 1rem 3rem;
      gap: 0.4rem;
    }

    .overlay-nav a {
      font-size: clamp(1.6rem, 2.8vw, 2.4rem);
      font-weight: 400;
      text-decoration: none;
      color: var(--off-white);
      line-height: 1.35;
      transition: color 0.2s;
      font-family: 'Georgia', serif;
    }

    .overlay-nav a:hover { color: var(--gold); }

    .overlay-footer {
      display: flex;
      align-items: flex-end;
      justify-content: flex-end;
      padding: 1.5rem 2rem;
      flex-shrink: 0;
      border-top: 1px solid rgba(201,165,90,0.1);
    }

    .overlay-legal {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.58rem;
      color: rgba(240, 235, 224, 0.42);
      letter-spacing: 0.05em;
      text-align: right;
      line-height: 1.6;
    }

    .overlay-legal a { color: rgba(240, 235, 224, 0.42); text-decoration: none; }
    .overlay-legal a:hover { color: var(--gold); }

    /* ── HERO — full-width, centered content ── */
    .hero {
      height: calc(100vh - var(--nav-h));
      height: calc(100svh - var(--nav-h)); /* iOS Safari: stable viewport height */
      margin-top: var(--nav-h);
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      overflow: hidden;
    }

    /* Full-width wave background */
    .hero-bg {
      position: absolute;
      inset: 0;
    }

    .hero-bg svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    /* Dark overlay for text readability */
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: rgba(6, 8, 8, 0.52);
    }

    /* Centered content */
    .hero-center {
      position: relative;
      z-index: 2;
      text-align: center;
      padding: 2rem clamp(1.5rem, 6vw, 5rem);
      max-width: min(900px, 92vw);
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    .hero-eyebrow {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.62rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
      margin: 0 0 1.1rem;
    }

    .hero-main-title {
      font-size: clamp(1.7rem, 3.8vw, 3rem);
      font-weight: 400;
      line-height: 1.18;
      color: var(--off-white);
      margin: 0 0 1.3rem;
      max-width: 780px;
    }

    .hero-summary {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.97rem;
      line-height: 1.78;
      color: rgba(240,235,224,0.70);
      max-width: 600px;
      margin: 0;
    }

    .hero-cta {
      margin-top: 1.6rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--off-white);
      border: 1px solid rgba(201,165,90,0.5);
      background: rgba(201,165,90,0.18);
      padding: 0.72rem 1rem;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }

    .hero-cta:hover {
      color: var(--gold);
      border-color: var(--gold);
      background: rgba(201,165,90,0.08);
    }

    /* Carousel bar — bottom of hero */
    .hero-carousel-bar {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0 2.5rem 2.5rem;
      flex-shrink: 0;
    }

    .carousel-tabs {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .carousel-arrow {
      background: none; border: none; cursor: pointer;
      color: var(--gold); font-size: 1.2rem;
      transition: color 0.2s;
      padding: 0.2rem 0.4rem;
    }
    .carousel-arrow:hover { color: var(--off-white); }

    .carousel-tab {
      border: none;
      background: transparent;
      color: var(--gray-light);
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 0.2rem 0.25rem 0.62rem;
      cursor: pointer;
      position: relative;
      transition: color 0.2s;
    }

    .carousel-tab::after {
      content: '';
      position: absolute;
      left: 0; right: 0; bottom: 0;
      height: 2px;
      background: var(--gray);
      transition: background 0.2s, height 0.2s;
    }

    .carousel-tab.active { color: var(--off-white); }
    .carousel-tab.active::after { height: 3px; background: var(--off-white); }
    /* Gold hover on carousel tabs */
    .carousel-tab:hover { color: var(--gold); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      /* Full-width overlay on mobile */
      .overlay {
        width: 100%;
        border-left: none;
      }

      .overlay-nav {
        align-items: flex-start;
        padding: 1rem 2rem;
      }

      .overlay-footer {
        justify-content: flex-start;
      }

      .overlay-legal { text-align: left; }
    }

    @media (max-width: 1024px) {
      :root { --nav-h: 112px; } /* 83px logo + 2×0.9rem padding ≈ 112px */

      nav#mainNav {
        padding: 0.9rem 1.2rem;
        min-height: var(--nav-h);
      }

      .logo-image { height: 83px; }
    }

    @media (max-width: 720px) {
      .logo-image { height: 73px; }
      .lang-switch { font-size: 0.5rem; letter-spacing: 0.14em; padding: 0.4rem 0.5rem; }
      .menu-btn-label { display: none; }
      .hero-carousel-bar { padding: 0 1.2rem 1.8rem; gap: 0.5rem; }
      .carousel-tab { font-size: 0.53rem; }
      .hero-center { padding: 1.5rem 1.2rem; }
    }

    @media (max-height: 700px) and (orientation: landscape) {
      :root { --nav-h: 87px; } /* 68px logo + 2×0.6rem padding ≈ 87px */

      nav#mainNav { min-height: var(--nav-h); padding-top: 0.6rem; padding-bottom: 0.6rem; }
      .logo-image { height: 68px; }
      .hero-main-title { font-size: clamp(1.3rem, 3.5vw, 2.2rem); }
      .hero-summary { display: none; }
    }

    /* ── CAROUSEL BAR — desktop: 15% margins left & right ── */
    @media (min-width: 721px) {
      .hero-carousel-bar {
        padding-left: 15vw;
        padding-right: 15vw;
      }
    }

    /* ── HOMEPAGE SECTIONS ── */
    .home-section {
      padding: 5rem clamp(1.5rem, 8vw, 7rem);
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-eyebrow {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
      margin: 0 0 0.8rem;
    }

    .section-title {
      font-size: clamp(1.5rem, 3vw, 2.4rem);
      font-weight: 400;
      color: var(--off-white);
      line-height: 1.2;
      margin: 0 0 2.5rem;
    }

    .section-divider {
      width: 100%;
      border: none;
      border-top: 1px solid rgba(201,165,90,0.12);
      margin: 0;
    }

    .practice-cards {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .practice-card {
      border: 1px solid rgba(201,165,90,0.15);
      padding: 2rem 1.8rem;
      transition: border-color 0.2s, background 0.2s;
    }

    .practice-card:hover {
      border-color: rgba(201,165,90,0.4);
      background: rgba(201,165,90,0.04);
    }

    .practice-card-number {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      color: var(--gold);
      margin-bottom: 0.8rem;
    }

    .practice-card h3 {
      font-size: 1.05rem;
      font-weight: 400;
      color: var(--off-white);
      margin-bottom: 0.75rem;
      line-height: 1.3;
    }

    .practice-card p {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.88rem;
      line-height: 1.72;
      color: rgba(240,235,224,0.6);
    }

    .section-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.68rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      transition: gap 0.2s, color 0.2s;
    }

    .section-cta:hover { color: var(--off-white); gap: 1rem; }
    .section-cta:hover svg { transform: translateX(3px); }
    .section-cta svg { flex-shrink: 0; transition: transform 0.2s; }

    .about-text p {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.97rem;
      line-height: 1.8;
      color: rgba(240,235,224,0.72);
      margin-bottom: 1.2rem;
      max-width: 720px;
    }

    .about-text p:last-of-type { margin-bottom: 2rem; }

    .site-footer {
      border-top: 1px solid rgba(201,165,90,0.12);
      padding: 2rem clamp(1.5rem, 8vw, 7rem);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .footer-copy {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.08em;
      color: rgba(240,235,224,0.38);
    }

    .footer-nav {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .footer-nav a {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      color: rgba(240,235,224,0.38);
      transition: color 0.2s;
    }

    .footer-nav a:hover { color: var(--gold); }

    @media (max-width: 720px) {
      .practice-cards { grid-template-columns: 1fr; }
      .site-footer { flex-direction: column; align-items: flex-start; }
    }

    /* ── HOMEPAGE CONTACT SECTION ── */
    .home-contact-wrap { border-top: 1px solid rgba(201,165,90,0.12); }

    .info-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-bottom: 1px solid rgba(201,165,90,0.12);
    }

    .info-card {
      padding: 1.8rem clamp(1.5rem, 8vw, 7rem);
      border-right: 1px solid rgba(201,165,90,0.12);
      display: flex; flex-direction: column; gap: 0.3rem;
    }
    .info-card:last-child { border-right: none; }

    .info-icon { margin-bottom: 0.4rem; color: var(--gold); }

    .info-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold);
    }

    .info-value {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.95rem; color: var(--off-white);
      text-decoration: none; font-style: normal; line-height: 1.55; transition: color 0.2s;
    }
    a.info-value:hover { color: var(--gold); }

    .contact-main {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      min-height: 500px;
    }

    .map-col {
      position: relative; background: #111;
      overflow: hidden; min-height: 400px;
    }
    .map-col iframe {
      position: absolute;
      width: 50%; height: 50%;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      border: 0; display: block;
    }

    .form-col {
      padding: 2.8rem clamp(1.5rem, 8vw, 7rem);
      background: rgba(10,10,10,0.6);
      display: flex; flex-direction: column; gap: 1.5rem;
    }

    .form-title {
      font-family: 'Georgia', serif;
      font-size: 1.45rem; font-weight: 400; color: var(--off-white);
    }

    #contactForm { display: flex; flex-direction: column; gap: 1.5rem; }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .form-group { display: flex; flex-direction: column; }

    .form-input,
    .form-textarea {
      width: 100%; background: transparent;
      border: none; border-bottom: 1px solid rgba(201,165,90,0.22);
      color: var(--off-white); padding: 0.75rem 0;
      font-family: 'Helvetica Neue', sans-serif; font-size: 0.9rem;
      outline: none; transition: border-color 0.2s;
      -webkit-appearance: none; border-radius: 0;
    }
    .form-input:focus, .form-textarea:focus { border-bottom-color: var(--gold); }
    .form-input::placeholder, .form-textarea::placeholder { color: var(--gray); font-size: 0.87rem; }
    .form-textarea { resize: none; min-height: 110px; line-height: 1.6; }

    .form-actions { display: flex; justify-content: flex-end; margin-top: 0.5rem; }

    .submit-btn {
      display: inline-flex; align-items: center; gap: 0.75rem;
      background: none; border: 1px solid rgba(201,165,90,0.45); color: var(--gold);
      padding: 0.85rem 1.6rem;
      font-family: 'Helvetica Neue', sans-serif; font-size: 0.68rem;
      letter-spacing: 0.18em; text-transform: uppercase; cursor: pointer; transition: all 0.2s;
    }
    .submit-btn:hover { background: rgba(201,165,90,0.1); border-color: var(--gold); }
    .submit-btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .btn-arrow { font-size: 1.1em; transition: transform 0.2s; }
    .submit-btn:not(:disabled):hover .btn-arrow { transform: translateX(4px); }

    .form-feedback {
      padding: 1rem 1.2rem;
      font-family: 'Helvetica Neue', sans-serif; font-size: 0.88rem; line-height: 1.55;
    }
    .form-feedback.success { border-left: 3px solid var(--gold); background: rgba(201,165,90,0.07); color: var(--off-white); }
    .form-feedback.error { border-left: 3px solid #b54040; background: rgba(181,64,64,0.08); color: var(--off-white); }
    .form-feedback a { color: var(--gold); }

    @media (max-width: 900px) {
      .info-strip { grid-template-columns: 1fr; }
      .info-card { border-right: none; border-bottom: 1px solid rgba(201,165,90,0.12); padding: 1.5rem 1.2rem; }
      .info-card:last-child { border-bottom: none; }
      .contact-main { grid-template-columns: 1fr; min-height: auto; }
      .map-col { height: 300px; min-height: 300px; }
    }

    @media (max-width: 720px) {
      .form-col { padding: 2rem 1.2rem; }
      .form-row { grid-template-columns: 1fr; }
      .form-actions { justify-content: stretch; }
      .submit-btn { width: 100%; justify-content: center; }
    }
  </style>
</head>
<body>

  <!-- BACKDROP -->
  <div class="overlay-backdrop" id="overlayBackdrop"></div>

  <!-- MENU OVERLAY PANEL -->
  <div class="overlay" id="overlay" role="dialog" aria-modal="true" aria-label="Meniu principal">
    <div class="overlay-top">
      <button class="close-btn" id="closeBtn" aria-label="Închide meniu">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <line x1="2" y1="2" x2="20" y2="20"/>
          <line x1="20" y1="2" x2="2" y2="20"/>
        </svg>
        <span class="close-label">Închide</span>
      </button>
    </div>

    <nav class="overlay-nav">
      <a href="/">Acasa</a>
      <a href="/despre-noi">Despre Noi</a>
      <a href="/arii-de-practica">Arii de Practica</a>
      <a href="/blog">Articole Juridice</a>
      <a href="/contact">Contact</a>
    </nav>

    <footer class="overlay-footer">
      <div class="overlay-legal">
        &copy; 2026 Societatea Civilă de Avocatură Marinescu &amp; Asociații
      </div>
    </footer>
  </div>

  <!-- TOPBAR -->
  <nav id="mainNav">
    <a href="/" class="logo" aria-label="SCA Marinescu, pagina principala">
      <img src="/company-logo-gold.svg" alt="Marinescu &amp; Asociații" class="logo-image" />
    </a>

    <div class="nav-right">
      <a href="/en/" class="lang-switch" hreflang="en" aria-label="English version">EN</a>

      <button class="menu-btn-wrap" id="menuBtn" aria-label="Deschide meniu" aria-expanded="false">
        <div class="menu-btn-icon">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <span class="menu-btn-label">Meniu</span>
      </button>
    </div>
  </nav>

  <!-- HERO — centered layout with full-width wave background -->
  <div class="hero">

    <!-- Wave background -->
    <div class="hero-bg">
