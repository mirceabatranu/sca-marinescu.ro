  <script>
    // ── Menu overlay ──
    const overlay = document.getElementById('overlay');
    const menuBtn = document.getElementById('menuBtn');
    const closeBtn = document.getElementById('closeBtn');
    const backdrop = document.getElementById('overlayBackdrop');
    const navEl = document.getElementById('mainNav');

    function openOverlay() {
      overlay.classList.add('open');
      backdrop.classList.add('visible');
      navEl.classList.add('menu-open');
      menuBtn.setAttribute('aria-expanded', 'true');
    }

    function closeOverlay() {
      overlay.classList.remove('open');
      backdrop.classList.remove('visible');
      navEl.classList.remove('menu-open');
      menuBtn.setAttribute('aria-expanded', 'false');
    }

    menuBtn.addEventListener('click', () => {
      overlay.classList.contains('open') ? closeOverlay() : openOverlay();
    });

    closeBtn.addEventListener('click', closeOverlay);
    backdrop.addEventListener('click', closeOverlay);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('open')) closeOverlay();
    });

    // ── Carousel ──
    const slides = [
      {
        eyebrow: 'Protejam interesele afacerii si personale cu solutii juridice strategice, orientate spre rezultate.',
        title: 'SCA Marinescu | Consiliere Juridica Experta si Reprezentare Dedicata in Romania',
        summary: 'La SCA Marinescu, facem mai mult decat sa navigam legea: oferim strategii proactive pentru a-ti securiza viitorul. Ca Societate Civila de Avocatura, echipa noastra este specializata in drept comercial, litigii civile si consultanta juridica pentru companii si persoane fizice. Fie ca inchei o fuziune complexa, gestionezi un litigiu cu miza ridicata sau ai nevoie de conformitate juridica de zi cu zi, livram solutii clare, aplicabile si personalizate.',
      },
      {
        eyebrow: 'Clienti',
        title: 'Reprezentare pentru companii si grupuri antreprenoriale',
        summary: 'Lucram cu societati comerciale, grupuri de actionari si parteneri internationali care au nevoie de claritate juridica in dispute cu miza ridicata.',
      },
      {
        eyebrow: 'Litigii Comerciale',
        title: 'Dispute contractuale, arbitraj si recuperare de creante',
        summary: 'Experienta in litigii complexe: neexecutare contractuala, blocaje societare, arbitraj institutional si recuperarea creantelor cu risc de disipare a activelor.',
      },
    ];

    const tabButtons = document.querySelectorAll('.carousel-tab');
    const prevSlide = document.getElementById('prevSlide');
    const nextSlide = document.getElementById('nextSlide');
    let activeIndex = 0;

    function renderSlide(index) {
      activeIndex = index;
      tabButtons.forEach((btn, i) => {
        const active = i === index;
        btn.classList.toggle('active', active);
        btn.setAttribute('aria-selected', String(active));
      });
      const s = slides[index];
      document.getElementById('heroEyebrow').textContent = s.eyebrow;
      document.getElementById('heroTitle').textContent = s.title;
      document.getElementById('heroSummary').textContent = s.summary;
    }

    tabButtons.forEach((btn, i) => btn.addEventListener('click', () => renderSlide(i)));
    prevSlide.addEventListener('click', () => renderSlide((activeIndex - 1 + slides.length) % slides.length));
    nextSlide.addEventListener('click', () => renderSlide((activeIndex + 1) % slides.length));

    renderSlide(0);
  </script>

  <script>
    import { initializeApp } from 'firebase/app';
    import { getFirestore, collection, addDoc, serverTimestamp } from 'firebase/firestore';

    const firebaseConfig = {
      apiKey: "AIzaSyBjyzP82ykcTlMVhEtK5vt9GKuj0apRKHI",
      authDomain: "sca-marinescu.firebaseapp.com",
      projectId: "sca-marinescu",
      storageBucket: "sca-marinescu.firebasestorage.app",
      messagingSenderId: "876649116317",
      appId: "1:876649116317:web:eeb8b2c3b87d4565065a74"
    };

    const app = initializeApp(firebaseConfig);
    const db  = getFirestore(app);

    const form       = document.getElementById('contactForm');
    const submitBtn  = document.getElementById('hcf-submit');
    const btnText    = submitBtn.querySelector('.btn-text');
    const successMsg = document.getElementById('hcf-success');
    const errorMsg   = document.getElementById('hcf-error');

    form.addEventListener('submit', async e => {
      e.preventDefault();
      errorMsg.hidden = true;

      const name    = document.getElementById('hcf-name').value.trim();
      const email   = document.getElementById('hcf-email').value.trim();
      const phone   = document.getElementById('hcf-phone').value.trim();
      const subject = document.getElementById('hcf-subject').value.trim();
      const message = document.getElementById('hcf-message').value.trim();

      if (!name || !email || !subject || !message) return;

      submitBtn.disabled = true;
      btnText.textContent = 'Se trimite…';

      try {
        await addDoc(collection(db, 'mail'), {
          to: ['office@sca-marinescu.ro'],
          replyTo: email,
          message: {
            subject: `[Contact SCA Marinescu] ${subject}`,
            html: `<div style="font-family:Arial,sans-serif;max-width:600px;padding:24px;color:#1a1a1a;"><h2 style="color:#10281f;border-bottom:2px solid #C9A55A;padding-bottom:8px;margin-bottom:16px;">Mesaj nou de pe site</h2><table style="width:100%;border-collapse:collapse;"><tr><td style="padding:7px 4px;color:#555;width:90px;">Nume:</td><td style="padding:7px 4px;font-weight:600;">${name}</td></tr><tr><td style="padding:7px 4px;color:#555;">Email:</td><td style="padding:7px 4px;">${email}</td></tr><tr><td style="padding:7px 4px;color:#555;">Telefon:</td><td style="padding:7px 4px;">${phone || '—'}</td></tr><tr><td style="padding:7px 4px;color:#555;">Subiect:</td><td style="padding:7px 4px;">${subject}</td></tr><tr><td style="padding:7px 4px;color:#555;vertical-align:top;">Mesaj:</td><td style="padding:7px 4px;line-height:1.65;">${message.replace(/\n/g,'<br>')}</td></tr></table></div>`,
            text: `Mesaj nou\n\nNume: ${name}\nEmail: ${email}\nTelefon: ${phone||'—'}\nSubiect: ${subject}\n\n${message}`
          },
          formData: { name, email, phone, subject, message },
          source: 'contact-homepage-ro',
          createdAt: serverTimestamp()
        });
        form.hidden = true;
        successMsg.hidden = false;
      } catch (err) {
        console.error('Firebase error:', err);
        errorMsg.hidden = false;
        submitBtn.disabled = false;
        btnText.textContent = 'Trimite Mesajul';
      }
    });
  </script>
