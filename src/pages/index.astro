        <img src="/company-logo-gold.svg" alt="Marinescu &amp; Asociații" class="logo-image" />
      </a>

      <div class="nav-right">
        <a href="/en/" class="lang-switch" hreflang="en" aria-label="English version">EN</a>

        <button class="menu-btn-wrap" id="menuBtn" aria-label="Deschide meniu" aria-expanded="false">
          <div class="menu-btn">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <span class="menu-label">Meniu</span>
        </button>
      </div>
    </nav>

    <!-- HERO -->
