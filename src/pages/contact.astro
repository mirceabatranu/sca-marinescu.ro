---
---
<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact | SCA Marinescu și Asociații</title>
  <meta name="description" content="Contactați SCA Marinescu și Asociații. Telefon: +40722.651.340. Email: office@sca-marinescu.ro. Sediu: Splaiul Unirii 16, Sector 4, București." />
  <link rel="canonical" href="https://sca-marinescu.ro/contact" />
  <link rel="alternate" href="https://sca-marinescu.ro/contact" hreflang="ro-RO" />
  <link rel="alternate" href="https://sca-marinescu.ro/en/contact" hreflang="en" />
  <link rel="alternate" href="https://sca-marinescu.ro/contact" hreflang="x-default" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #C9A55A;
      --dark: #0E0D0C;
      --dark-nav: #131210;
      --dark-alt: #0a0a0a;
      --off-white: #F0EBE0;
      --gray: #6B6860;
      --gray-light: #9A9590;
      --line: rgba(201, 165, 90, 0.14);
      --nav-h: 130px;
    }

    html, body { min-height: 100%; overflow-x: hidden; }
    html { scroll-padding-top: var(--nav-h); }

    body {
      font-family: 'Georgia', serif;
      background: var(--dark);
      color: var(--off-white);
    }

    .shell {
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 2.5rem;
    }

    /* ── NAV ── */
    nav#mainNav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 300;
      display: flex;
      align-items: center;
      padding: 1rem 2.5rem;
      min-height: var(--nav-h);
      background: var(--dark-nav);
      border-bottom: 1px solid var(--line);
    }

    .logo {
      text-decoration: none;
      flex-shrink: 0;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .logo-image { display: block; height: 98px; width: auto; }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-left: auto;
    }

    .lang-switch {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.56rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--gold);
      border: 1px solid rgba(201,165,90,0.35);
      padding: 0.45rem 0.7rem;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
      white-space: nowrap;
    }
    .lang-switch:hover { color: var(--off-white); border-color: var(--gold); background: rgba(201,165,90,0.12); }

    .menu-btn-icon { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
    .menu-btn-icon span { display: block; height: 1.5px; background: var(--gold); }
    .menu-btn-icon span:nth-child(1) { width: 22px; }
    .menu-btn-icon span:nth-child(2) { width: 16px; }
    .menu-btn-icon span:nth-child(3) { width: 22px; }

    .menu-btn-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.5rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-top: 0.3rem;
    }

    .menu-btn-wrap {
      display: flex; flex-direction: column; align-items: center;
      cursor: pointer; background: none; border: none;
    }

    @media (min-width: 901px) {
      nav#mainNav.menu-open .logo { transform: translateX(-2rem); }
    }

    /* ── BACKDROP ── */
    .overlay-backdrop {
      position: fixed; inset: 0; z-index: 199;
      background: rgba(0,0,0,0.55);
      opacity: 0; pointer-events: none;
      transition: opacity 0.4s ease;
    }
    .overlay-backdrop.visible { opacity: 1; pointer-events: all; }

    /* ── OVERLAY MENU ── */
    .overlay {
      position: fixed; top: 0; right: 0;
      width: 40%; height: 100vh; z-index: 200;
      background: var(--dark);
      display: flex; flex-direction: column;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      overflow-y: auto; overflow-x: hidden;
      border-left: 1px solid var(--line);
    }
    .overlay.open { transform: translateX(0); }

    .overlay-top {
      display: flex; align-items: center; justify-content: flex-end;
      padding: 1.6rem 2rem; flex-shrink: 0;
    }

    .close-btn {
      background: none; border: none; cursor: pointer;
      display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
      color: var(--off-white); transition: color 0.2s;
    }
    .close-btn:hover { color: var(--gold); }
    .close-btn svg { stroke: currentColor; stroke-width: 1.5; }

    .close-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.5rem; letter-spacing: 0.3em; text-transform: uppercase; color: inherit;
    }

    .overlay-nav {
      flex: 1; display: flex; flex-direction: column;
      justify-content: center; align-items: flex-start;
      padding: 1rem 3rem; gap: 0.4rem;
    }
    .overlay-nav a {
      font-size: clamp(1.6rem, 2.8vw, 2.4rem);
      font-weight: 400; text-decoration: none;
      color: var(--off-white); line-height: 1.35; transition: color 0.2s;
    }
    .overlay-nav a:hover,
    .overlay-nav a[aria-current="page"] { color: var(--gold); }

    .overlay-footer { padding: 1.5rem 2rem; flex-shrink: 0; border-top: 1px solid rgba(201,165,90,0.1); }
    .overlay-legal {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.58rem; color: rgba(240,235,224,0.42);
      letter-spacing: 0.05em; line-height: 1.6;
    }

    /* ── CONTACT PAGE ── */
    .contact-page { padding-top: var(--nav-h); display: flex; flex-direction: column; min-height: 100vh; }

    .eyebrow {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.62rem; letter-spacing: 0.35em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 0.75rem;
    }

    .contact-title {
      font-family: 'Georgia', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 400; line-height: 1.1; color: var(--off-white);
    }

    .page-lead {
      margin-top: 0.6rem; margin-bottom: 2rem;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.95rem; color: var(--gray-light); line-height: 1.7;
    }

    .form-col-divider {
      border: none; border-top: 1px solid var(--line); margin-bottom: 2rem;
    }

    /* Info Strip */
    .info-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-bottom: 1px solid var(--line);
    }

    .info-card {
      padding: 1.8rem 2rem;
      border-right: 1px solid var(--line);
      display: flex; flex-direction: column; gap: 0.3rem;
    }
    .info-card:last-child { border-right: none; }

    .info-icon { margin-bottom: 0.4rem; color: var(--gold); }

    .info-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold);
    }

    .info-value {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.95rem; color: var(--off-white);
      text-decoration: none; font-style: normal; line-height: 1.55;
      transition: color 0.2s;
    }
    a.info-value:hover { color: var(--gold); }

    /* Map + Form */
    .contact-main {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      flex: 1;
      min-height: 580px;
    }

    .map-col {
      position: relative;
      background: #111;
      overflow: hidden;
      min-height: 500px;
    }
    .map-col iframe {
      position: absolute;
      width: 50%; height: 50%;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      border: 0; display: block;
    }

    .form-col {
      padding: 2.8rem 2.5rem;
      background: var(--dark-alt);
      display: flex; flex-direction: column;
    }

    .form-title {
      font-family: 'Georgia', serif;
      font-size: 1.45rem; font-weight: 400;
      color: var(--off-white); margin-bottom: 2rem;
    }

    #contactForm { display: flex; flex-direction: column; gap: 1.5rem; }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }

    .form-group { display: flex; flex-direction: column; }

    .form-input,
    .form-textarea {
      width: 100%;
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(201,165,90,0.22);
      color: var(--off-white);
      padding: 0.75rem 0;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.9rem;
      outline: none;
      transition: border-color 0.2s;
      -webkit-appearance: none;
      border-radius: 0;
    }
    .form-input:focus,
    .form-textarea:focus { border-bottom-color: var(--gold); }
    .form-input::placeholder,
    .form-textarea::placeholder { color: var(--gray); font-size: 0.87rem; }
    .form-textarea { resize: none; min-height: 110px; line-height: 1.6; }

    .form-actions { display: flex; justify-content: flex-end; margin-top: 0.5rem; }

    .submit-btn {
      display: inline-flex; align-items: center; gap: 0.75rem;
      background: none;
      border: 1px solid rgba(201,165,90,0.45);
      color: var(--gold);
      padding: 0.85rem 1.6rem;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase;
      cursor: pointer; transition: all 0.2s;
    }
    .submit-btn:hover { background: rgba(201,165,90,0.1); border-color: var(--gold); }
    .submit-btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .btn-arrow { font-size: 1.1em; transition: transform 0.2s; }
    .submit-btn:not(:disabled):hover .btn-arrow { transform: translateX(4px); }

    .form-feedback {
      margin-top: 1.25rem; padding: 1rem 1.2rem;
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.88rem; line-height: 1.55;
    }
    .form-feedback.success {
      border-left: 3px solid var(--gold);
      background: rgba(201,165,90,0.07);
      color: var(--off-white);
    }
    .form-feedback.error {
      border-left: 3px solid #b54040;
      background: rgba(181,64,64,0.08);
      color: var(--off-white);
    }
    .form-feedback a { color: var(--gold); }

    /* Footer */
    .site-footer {
      background: var(--dark-nav);
      border-top: 1px solid var(--line);
      padding: 1.5rem 0;
    }
    .footer-inner {
      display: flex; align-items: center;
      justify-content: space-between; gap: 1rem;
    }
    .footer-inner p {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.68rem; letter-spacing: 0.05em;
      color: rgba(240,235,224,0.4);
    }
    .footer-links { display: flex; gap: 1.5rem; flex-wrap: wrap; }
    .footer-links a {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;
      text-decoration: none; color: rgba(240,235,224,0.45); transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--gold); }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      :root { --nav-h: 112px; }
      nav#mainNav { padding: 0.9rem 1.2rem; min-height: var(--nav-h); }
      .logo-image { height: 83px; }
    }

    @media (max-width: 900px) {
      .overlay { width: 100%; border-left: none; }
      .overlay-nav { padding: 1rem 2rem; }
      .overlay-footer { padding: 1.5rem 2rem; }

      .info-strip { grid-template-columns: 1fr; }
      .info-card { border-right: none; border-bottom: 1px solid var(--line); }
      .info-card:last-child { border-bottom: none; }

      .contact-main { grid-template-columns: 1fr; min-height: auto; }
      .map-col { height: 320px; min-height: 320px; }

      .footer-inner { flex-direction: column; align-items: flex-start; }
    }

    @media (max-width: 720px) {
      .logo-image { height: 73px; }
      .menu-btn-label { display: none; }
      .shell { padding: 0 1.2rem; }
      .form-col { padding: 2rem 1.5rem; }
      .form-row { grid-template-columns: 1fr; }
      .form-actions { justify-content: stretch; }
      .submit-btn { width: 100%; justify-content: center; }
      .footer-links { gap: 1rem; }
    }

    @media (max-height: 700px) and (orientation: landscape) {
      :root { --nav-h: 87px; }
      nav#mainNav { min-height: var(--nav-h); padding-top: 0.6rem; padding-bottom: 0.6rem; }
      .logo-image { height: 68px; }
    }
  </style>
</head>
<body>

  <div class="overlay-backdrop" id="overlayBackdrop"></div>

  <div class="overlay" id="overlay" role="dialog" aria-modal="true" aria-label="Meniu principal">
    <div class="overlay-top">
      <button class="close-btn" id="closeBtn" aria-label="Închide meniu">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <line x1="2" y1="2" x2="20" y2="20"/>
          <line x1="20" y1="2" x2="2" y2="20"/>
        </svg>
        <span class="close-label">Închide</span>
      </button>
    </div>
    <nav class="overlay-nav">
      <a href="/">Acasă</a>
      <a href="/despre-noi">Despre Noi</a>
      <a href="/arii-de-practica">Arii de Practică</a>
      <a href="/blog">Blog Juridic</a>
      <a href="/contact" aria-current="page">Contact</a>
    </nav>
    <footer class="overlay-footer">
      <div class="overlay-legal">&copy; 2026 Societatea Civilă de Avocatură Marinescu &amp; Asociații</div>
    </footer>
  </div>

  <nav id="mainNav">
    <a href="/" class="logo" aria-label="SCA Marinescu, pagina principala">
      <img src="/company-logo-gold.svg" alt="Marinescu &amp; Asociații" class="logo-image" />
    </a>
    <div class="nav-right">
      <a href="/en/contact" class="lang-switch" hreflang="en" aria-label="English version">EN</a>
      <button class="menu-btn-wrap" id="menuBtn" aria-label="Deschide meniu" aria-expanded="false">
        <div class="menu-btn-icon"><span></span><span></span><span></span></div>
        <span class="menu-btn-label">Meniu</span>
      </button>
    </div>
  </nav>

  <main class="contact-page">

    <div class="info-strip">
      <div class="info-card">
        <div class="info-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.42 2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11l-1.27 1.27a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        </div>
        <span class="info-label">Telefon</span>
        <a href="tel:+40722651340" class="info-value">+40722.651.340</a>
      </div>
      <div class="info-card">
        <div class="info-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </div>
        <span class="info-label">Email</span>
        <a href="mailto:office@sca-marinescu.ro" class="info-value">office@sca-marinescu.ro</a>
      </div>
      <div class="info-card">
        <div class="info-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <span class="info-label">Sediu</span>
        <address class="info-value">Splaiul Unirii 16<br />Sector 4, București</address>
      </div>
    </div>

    <section class="contact-main">
      <div class="map-col">
        <iframe
          src="https://maps.google.com/maps?q=Splaiul+Unirii+16+Sector+4+Bucharest+Romania&output=embed&hl=ro"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Locație SCA Marinescu — Splaiul Unirii 16, Sector 4, București"
          allowfullscreen>
        </iframe>
      </div>

      <div class="form-col">
        <p class="eyebrow">SCA Marinescu și Asociații</p>
        <h1 class="contact-title">Contact</h1>
        <p class="page-lead">Suntem la dispoziția dumneavoastră pentru consultații și orice alte informații.</p>
        <hr class="form-col-divider" />
        <h2 class="form-title">Trimiteți-ne un mesaj</h2>

        <form id="contactForm" novalidate>
          <div class="form-group">
            <input type="text" id="name" name="name" class="form-input"
              placeholder="Nume și prenume *" required autocomplete="name" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <input type="email" id="email" name="email" class="form-input"
                placeholder="Adresă email *" required autocomplete="email" />
            </div>
            <div class="form-group">
              <input type="tel" id="phone" name="phone" class="form-input"
                placeholder="Telefon" autocomplete="tel" />
            </div>
          </div>
          <div class="form-group">
            <input type="text" id="subject" name="subject" class="form-input"
              placeholder="Subiect *" required />
          </div>
          <div class="form-group">
            <textarea id="message" name="message" class="form-textarea"
              placeholder="Mesajul dumneavoastră *" required rows="5"></textarea>
          </div>
          <div class="form-actions">
            <button type="submit" class="submit-btn" id="submitBtn">
              <span class="btn-text">Trimite Mesajul</span>
              <span class="btn-arrow">→</span>
            </button>
          </div>
        </form>

        <div id="formSuccess" class="form-feedback success" hidden>
          Mesajul dumneavoastră a fost trimis cu succes. Vă vom contacta în cel mai scurt timp.
        </div>
        <div id="formError" class="form-feedback error" hidden>
          A apărut o eroare. Contactați-ne direct la
          <a href="mailto:office@sca-marinescu.ro">office@sca-marinescu.ro</a>
        </div>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="shell">
      <div class="footer-inner">
        <p>&copy; 2026 Societatea Civilă de Avocatură Marinescu &amp; Asociații</p>
        <nav class="footer-links" aria-label="Footer">
          <a href="/arii-de-practica">Arii de Practică</a>
          <a href="/despre-noi">Despre Noi</a>
          <a href="/blog">Blog Juridic</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </div>
  </footer>

  <script>
    // ── Nav overlay ──
    const overlay = document.getElementById('overlay');
    const menuBtn = document.getElementById('menuBtn');
    const closeBtn = document.getElementById('closeBtn');
    const backdrop = document.getElementById('overlayBackdrop');
    const navEl   = document.getElementById('mainNav');

    const openOverlay = () => {
      overlay.classList.add('open');
      backdrop.classList.add('visible');
      navEl.classList.add('menu-open');
      menuBtn.setAttribute('aria-expanded', 'true');
    };
    const closeOverlay = () => {
      overlay.classList.remove('open');
      backdrop.classList.remove('visible');
      navEl.classList.remove('menu-open');
      menuBtn.setAttribute('aria-expanded', 'false');
    };

    menuBtn.addEventListener('click', () =>
      overlay.classList.contains('open') ? closeOverlay() : openOverlay()
    );
    closeBtn.addEventListener('click', closeOverlay);
    backdrop.addEventListener('click', closeOverlay);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && overlay.classList.contains('open')) closeOverlay();
    });
    document.querySelectorAll('.overlay-nav a').forEach(a =>
      a.addEventListener('click', closeOverlay)
    );

    // ── Contact form → Firebase Firestore → Trigger Email extension ──
    //
    // SETUP REQUIRED (one-time, in Firebase Console):
    // 1. Enable Firestore Database in your Firebase project
    // 2. Install "Trigger Email by Firebase" extension:
    //    https://extensions.dev/extensions/firebase/firestore-send-email
    //    - Collection: mail
    //    - SMTP URI: smtp://office%40sca-marinescu.ro:APP_PASSWORD@smtp.office365.com:587
    //    - Default FROM: SCA Marinescu <office@sca-marinescu.ro>
    // 3. Add Firestore Security Rules:
    //    match /mail/{doc} {
    //      allow create: if request.resource.data.source in ['contact-ro','contact-en'];
    //      allow read, update, delete: if false;
    //    }

    import { initializeApp } from 'firebase/app';
    import { getFirestore, collection, addDoc, serverTimestamp } from 'firebase/firestore';

    const firebaseConfig = {
      apiKey: "AIzaSyBjyzP82ykcTlMVhEtK5vt9GKuj0apRKHI",
      authDomain: "sca-marinescu.firebaseapp.com",
      projectId: "sca-marinescu",
      storageBucket: "sca-marinescu.firebasestorage.app",
      messagingSenderId: "876649116317",
      appId: "1:876649116317:web:eeb8b2c3b87d4565065a74"
    };

    const app  = initializeApp(firebaseConfig);
    const db   = getFirestore(app);

    const form       = document.getElementById('contactForm');
    const submitBtn  = document.getElementById('submitBtn');
    const btnText    = submitBtn.querySelector('.btn-text');
    const successMsg = document.getElementById('formSuccess');
    const errorMsg   = document.getElementById('formError');

    form.addEventListener('submit', async e => {
      e.preventDefault();
      errorMsg.hidden = true;

      const name    = document.getElementById('name').value.trim();
      const email   = document.getElementById('email').value.trim();
      const phone   = document.getElementById('phone').value.trim();
      const subject = document.getElementById('subject').value.trim();
      const message = document.getElementById('message').value.trim();

      if (!name || !email || !subject || !message) return;

      submitBtn.disabled = true;
      btnText.textContent = 'Se trimite…';

      try {
        await addDoc(collection(db, 'mail'), {
          to: ['office@sca-marinescu.ro'],
          replyTo: email,
          message: {
            subject: `[Contact SCA Marinescu] ${subject}`,
            html: `
              <div style="font-family:Arial,sans-serif;max-width:600px;padding:24px;color:#1a1a1a;">
                <h2 style="color:#10281f;border-bottom:2px solid #C9A55A;padding-bottom:8px;margin-bottom:16px;">
                  Mesaj nou de pe site
                </h2>
                <table style="width:100%;border-collapse:collapse;">
                  <tr><td style="padding:7px 4px;color:#555;width:90px;">Nume:</td>
                      <td style="padding:7px 4px;font-weight:600;">${name}</td></tr>
                  <tr><td style="padding:7px 4px;color:#555;">Email:</td>
                      <td style="padding:7px 4px;">${email}</td></tr>
                  <tr><td style="padding:7px 4px;color:#555;">Telefon:</td>
                      <td style="padding:7px 4px;">${phone || '—'}</td></tr>
                  <tr><td style="padding:7px 4px;color:#555;">Subiect:</td>
                      <td style="padding:7px 4px;">${subject}</td></tr>
                  <tr><td style="padding:7px 4px;color:#555;vertical-align:top;">Mesaj:</td>
                      <td style="padding:7px 4px;line-height:1.65;">${message.replace(/\n/g,'<br>')}</td></tr>
                </table>
                <p style="margin-top:20px;color:#aaa;font-size:11px;border-top:1px solid #eee;padding-top:10px;">
                  Trimis de pe sca-marinescu.ro
                </p>
              </div>`,
            text: `Mesaj nou de pe sca-marinescu.ro\n\nNume: ${name}\nEmail: ${email}\nTelefon: ${phone||'—'}\nSubiect: ${subject}\n\nMesaj:\n${message}`
          },
          formData: { name, email, phone, subject, message },
          source: 'contact-ro',
          createdAt: serverTimestamp()
        });

        form.hidden = true;
        successMsg.hidden = false;
      } catch (err) {
        console.error('Firebase error:', err);
        errorMsg.hidden = false;
        submitBtn.disabled = false;
        btnText.textContent = 'Trimite Mesajul';
      }
    });
  </script>

</body>
</html>
