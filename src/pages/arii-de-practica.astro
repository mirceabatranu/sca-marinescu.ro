  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #C9A55A;
      --dark: #0E0D0C;
      --dark-nav: #131210;
      --off-white: #F0EBE0;
      --gray: #6B6860;
      --gray-light: #9A9590;
      --line: rgba(201, 165, 90, 0.14);
      --nav-h: 130px;
    }

    html, body { min-height: 100%; overflow-x: hidden; }
    html { scroll-padding-top: var(--nav-h); }
    body { font-family: 'Georgia', serif; background: var(--dark); color: var(--off-white); }

    .shell { max-width: 1120px; margin: 0 auto; padding: 0 2.5rem; }

    /* ── NAV ── */
    nav#mainNav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 300;
      display: flex; align-items: center;
      padding: 1rem 2.5rem; min-height: var(--nav-h);
      background: var(--dark-nav); border-bottom: 1px solid var(--line);
    }
    .logo { text-decoration: none; flex-shrink: 0; transition: transform 0.4s cubic-bezier(0.4,0,0.2,1); }
    .logo-image { display: block; height: 98px; width: auto; }
    .nav-right { display: flex; align-items: center; gap: 1rem; margin-left: auto; }
    .lang-switch {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.56rem; letter-spacing: 0.18em; text-transform: uppercase;
      text-decoration: none; color: var(--gold);
      border: 1px solid rgba(201,165,90,0.35); padding: 0.45rem 0.7rem;
      transition: border-color 0.2s, color 0.2s, background 0.2s; white-space: nowrap;
    }
    .lang-switch:hover { color: var(--off-white); border-color: var(--gold); background: rgba(201,165,90,0.12); }
    .menu-btn-icon { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
    .menu-btn-icon span { display: block; height: 1.5px; background: var(--gold); }
    .menu-btn-icon span:nth-child(1) { width: 22px; }
    .menu-btn-icon span:nth-child(2) { width: 16px; }
    .menu-btn-icon span:nth-child(3) { width: 22px; }
    .menu-btn-label { font-family: 'Helvetica Neue', sans-serif; font-size: 0.5rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold); margin-top: 0.3rem; }
    .menu-btn-wrap { display: flex; flex-direction: column; align-items: center; cursor: pointer; background: none; border: none; }

    @media (min-width: 901px) { nav#mainNav.menu-open .logo { transform: translateX(-2rem); } }

    /* ── BACKDROP ── */
    .overlay-backdrop { position: fixed; inset: 0; z-index: 199; background: rgba(0,0,0,0.55); opacity: 0; pointer-events: none; transition: opacity 0.4s ease; }
    .overlay-backdrop.visible { opacity: 1; pointer-events: all; }

    /* ── OVERLAY MENU ── */
    .overlay {
      position: fixed; top: 0; right: 0; width: 40%; height: 100vh; z-index: 200;
      background: var(--dark); display: flex; flex-direction: column;
      transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
      overflow-y: auto; overflow-x: hidden; border-left: 1px solid var(--line);
    }
    .overlay.open { transform: translateX(0); }
    .overlay-top { display: flex; align-items: center; justify-content: flex-end; padding: 1.6rem 2rem; flex-shrink: 0; }
    .close-btn { background: none; border: none; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 0.3rem; color: var(--off-white); transition: color 0.2s; }
    .close-btn:hover { color: var(--gold); }
    .close-btn svg { stroke: currentColor; stroke-width: 1.5; }
    .close-label { font-family: 'Helvetica Neue', sans-serif; font-size: 0.5rem; letter-spacing: 0.3em; text-transform: uppercase; color: inherit; }
    .overlay-nav { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; padding: 1rem 3rem; gap: 0.4rem; }
    .overlay-nav a { font-size: clamp(1.6rem, 2.8vw, 2.4rem); font-weight: 400; text-decoration: none; color: var(--off-white); line-height: 1.35; transition: color 0.2s; font-family: 'Georgia', serif; }
    .overlay-nav a:hover, .overlay-nav a[aria-current="page"] { color: var(--gold); }
    .overlay-footer { padding: 1.5rem 2rem; flex-shrink: 0; border-top: 1px solid rgba(201,165,90,0.1); }
    .overlay-legal { font-family: 'Helvetica Neue', sans-serif; font-size: 0.58rem; color: rgba(240,235,224,0.42); letter-spacing: 0.05em; line-height: 1.6; }

    /* ── PAGE LAYOUT ── */
    .page-wrap { padding-top: var(--nav-h); min-height: 100vh; display: flex; flex-direction: column; }

    .page-header { padding: 3.5rem 0; border-bottom: 1px solid var(--line); }

    .eyebrow {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.62rem; letter-spacing: 0.35em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 0.75rem;
    }

    .page-h1 {
      font-family: 'Georgia', serif;
      font-size: clamp(2rem, 4.5vw, 3.4rem);
      font-weight: 400; line-height: 1.1; color: var(--off-white);
    }

    .page-body { flex: 1; }

    .content-section { padding: 3rem 0; border-bottom: 1px solid var(--line); }
    .content-section:last-child { border-bottom: none; padding-bottom: 4.5rem; }

    .section-label {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.58rem; letter-spacing: 0.32em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 0.8rem;
    }

    .section-intro {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.97rem; line-height: 1.8; color: rgba(240,235,224,0.72);
      max-width: 760px; margin-bottom: 2.2rem;
    }

    .section-note {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.97rem; line-height: 1.8; color: rgba(240,235,224,0.72);
      max-width: 760px; margin-bottom: 2rem;
    }

    /* Practice items */
    .practice-list { display: flex; flex-direction: column; gap: 1rem; max-width: 900px; }

    .practice-item {
      display: grid; grid-template-columns: 1.6rem 1fr; gap: 1rem;
      padding: 1.6rem 1.8rem;
      border: 1px solid rgba(201,165,90,0.15);
      transition: border-color 0.25s, background 0.25s;
    }
    .practice-item:hover {
      border-color: rgba(201,165,90,0.42);
      background: rgba(201,165,90,0.04);
    }

    .practice-diamond {
      color: var(--gold); font-size: 1rem; line-height: 1.6; flex-shrink: 0;
    }

    .practice-title {
      font-family: 'Georgia', serif;
      font-size: 1rem; font-weight: 400; color: var(--off-white); margin-bottom: 0.4rem;
    }

    .practice-text {
      font-family: 'Helvetica Neue', sans-serif;
      font-size: 0.88rem; line-height: 1.72; color: rgba(240,235,224,0.6);
    }

    /* Footer */
    .site-footer { background: var(--dark-nav); border-top: 1px solid var(--line); padding: 1.5rem 0; }
    .footer-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .footer-inner p { font-family: 'Helvetica Neue', sans-serif; font-size: 0.68rem; letter-spacing: 0.05em; color: rgba(240,235,224,0.4); }
    .footer-links { display: flex; gap: 1.5rem; flex-wrap: wrap; }
    .footer-links a { font-family: 'Helvetica Neue', sans-serif; font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; color: rgba(240,235,224,0.45); transition: color 0.2s; }
    .footer-links a:hover { color: var(--gold); }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      :root { --nav-h: 112px; }
      nav#mainNav { padding: 0.9rem 1.2rem; min-height: var(--nav-h); }
      .logo-image { height: 83px; }
    }
    @media (max-width: 900px) {
      .overlay { width: 100%; border-left: none; }
      .overlay-nav { padding: 1rem 2rem; }
      .footer-inner { flex-direction: column; align-items: flex-start; }
    }
    @media (max-width: 720px) {
      .logo-image { height: 73px; }
      .menu-btn-label { display: none; }
      .shell { padding: 0 1.2rem; }
      .footer-links { gap: 1rem; }
      .practice-item { padding: 1.2rem 1rem; }
    }
    @media (max-height: 700px) and (orientation: landscape) {
      :root { --nav-h: 87px; }
      nav#mainNav { min-height: var(--nav-h); padding-top: 0.6rem; padding-bottom: 0.6rem; }
      .logo-image { height: 68px; }
    }
  </style>
</head>
<body>

  <div class="overlay-backdrop" id="overlayBackdrop"></div>

  <div class="overlay" id="overlay" role="dialog" aria-modal="true" aria-label="Meniu principal">
    <div class="overlay-top">
      <button class="close-btn" id="closeBtn" aria-label="Închide meniu">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <line x1="2" y1="2" x2="20" y2="20"/>
